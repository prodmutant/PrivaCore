<Window x:Class="PROSCANNERCONT.Views.WidgetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Add Widgets" Width="480" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <fa:IconBlock Icon="TableCellsLarge" Foreground="{DynamicResource AccentBrush}"
                                      Width="15" Height="15" Margin="0,0,10,0"/>
                        <TextBlock Text="Add Widgets" Foreground="{DynamicResource TextBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   FontFamily="{DynamicResource PrimaryFont}"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Done_Click" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                            Width="30" Height="30" FontSize="16">✕</Button>
                </Grid>
            </Border>

            <!-- Subtitle -->
            <TextBlock Grid.Row="1" Margin="18,10,18,6"
                       Text="Click a widget to add or remove it from your dashboard. Resize and reorder directly on the dashboard."
                       Foreground="{DynamicResource TextBrush}" Opacity="0.5"
                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       TextWrapping="Wrap"/>

            <!-- Thumbnail grid (built in code-behind) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Padding="14,4,14,4">
                <WrapPanel x:Name="TilePanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <Grid Margin="16,0">
                    <Button Content="Reset Defaults" HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource BaseButtonStyle}"
                            Height="30" Padding="12,0"
                            Click="ResetDefaults_Click"/>
                    <Button Content="Done" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="30" Width="80"
                            Click="Done_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
