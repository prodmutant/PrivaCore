<Page x:Class="PROSCANNERCONT.Views.AchievementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:converters="clr-namespace:PROSCANNERCONT.ValueConverters"
      xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
      Background="{DynamicResource BackgroundBrush}"
      Title="Achievements">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Achievements Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Security Achievements" 
                           Foreground="{DynamicResource TextBrush}" 
                           FontSize="24" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="Track your network security milestones and progress"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.7"
                           FontSize="14"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Overall Progress -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="200"
                    Height="80"
                    Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#FFD700"
                            Width="40"
                            Height="40"
                            CornerRadius="20">
                        <fa:IconBlock Icon="Trophy" 
                                        Foreground="White"
                                        Width="20"
                                        Height="20"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="OverallProgressText"
                                   Text="0/30"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Achievements Earned"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12"
                                   Opacity="0.7"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Progress Stats -->
        <WrapPanel Grid.Row="1" Margin="0,20,0,20">
            <!-- Security Expert Card -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="180"
                    Height="120"
                    Margin="0,0,20,20">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FF2196F3"
                                Width="24"
                                Height="24"
                                CornerRadius="12">
                            <fa:IconBlock Icon="Shield" 
                                            Foreground="White"
                                            Width="12"
                                            Height="12"/>
                        </Border>
                        <TextBlock Text="Security Expert"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="SecurityExpertText"
                               Text="0/10"
                               Grid.Row="1"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <ProgressBar x:Name="SecurityExpertProgress"
                                 Grid.Row="2"
                                 Value="0"
                                 Maximum="100"
                                 Height="6"
                                 Background="{DynamicResource BorderBrush}"
                                 Foreground="#FF2196F3"
                                 BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- Network Scout Card -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="180"
                    Height="120"
                    Margin="0,0,20,20">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FF4CAF50"
                                Width="24"
                                Height="24"
                                CornerRadius="12">
                            <fa:IconBlock Icon="MagnifyingGlass" 
                                            Foreground="White"
                                            Width="12"
                                            Height="12"/>
                        </Border>
                        <TextBlock Text="Network Scout"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="NetworkScoutText"
                               Text="0/8"
                               Grid.Row="1"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <ProgressBar x:Name="NetworkScoutProgress"
                                 Grid.Row="2"
                                 Value="0"
                                 Maximum="100"
                                 Height="6"
                                 Background="{DynamicResource BorderBrush}"
                                 Foreground="#FF4CAF50"
                                 BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- Bug Hunter Card -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="180"
                    Height="120"
                    Margin="0,0,20,20">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FFFF5722"
                                Width="24"
                                Height="24"
                                CornerRadius="12">
                            <fa:IconBlock Icon="Bug" 
                                            Foreground="White"
                                            Width="12"
                                            Height="12"/>
                        </Border>
                        <TextBlock Text="Bug Hunter"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="BugHunterText"
                               Text="0/6"
                               Grid.Row="1"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <ProgressBar x:Name="BugHunterProgress"
                                 Grid.Row="2"
                                 Value="0"
                                 Maximum="100"
                                 Height="6"
                                 Background="{DynamicResource BorderBrush}"
                                 Foreground="#FFFF5722"
                                 BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- Performance Expert Card -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="180"
                    Height="120"
                    Margin="0,0,20,20">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FF9C27B0"
                                Width="24"
                                Height="24"
                                CornerRadius="12">
                            <fa:IconBlock Icon="Bolt" 
                                            Foreground="White"
                                            Width="12"
                                            Height="12"/>
                        </Border>
                        <TextBlock Text="Performance Expert"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="PerformanceExpertText"
                               Text="0/6"
                               Grid.Row="1"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <ProgressBar x:Name="PerformanceExpertProgress"
                                 Grid.Row="2"
                                 Value="0"
                                 Maximum="100"
                                 Height="6"
                                 Background="{DynamicResource BorderBrush}"
                                 Foreground="#FF9C27B0"
                                 BorderThickness="0"/>
                </Grid>
            </Border>
        </WrapPanel>

        <!-- Achievements List -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with Filter -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="All Achievements"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="AllAchievementsButton"
                                Style="{StaticResource BaseButtonStyle}"
                                Content="All"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="FilterAchievements_Click"
                                Tag="All"/>
                        <Button x:Name="EarnedAchievementsButton"
                                Style="{StaticResource BaseButtonStyle}"
                                Content="Earned"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="FilterAchievements_Click"
                                Tag="Earned"/>
                        <Button x:Name="LockedAchievementsButton"
                                Style="{StaticResource BaseButtonStyle}"
                                Content="Locked"
                                Padding="12,6"
                                Click="FilterAchievements_Click"
                                Tag="Locked"/>
                    </StackPanel>
                </Grid>

                <!-- Achievements Grid with Enhanced Scroll -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,20,0,0"
                              CanContentScroll="True"
                              PanningMode="VerticalOnly">
                    <Grid x:Name="AchievementsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <!-- Achievement Template for Left Column -->
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <!-- Achievement Template for Right Column -->
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>