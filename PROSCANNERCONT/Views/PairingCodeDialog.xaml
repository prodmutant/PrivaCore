<Window x:Class="PROSCANNERCONT.Views.PairingCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Pairing code" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- title bar -->
            <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <fa:IconBlock Icon="Key" Foreground="{DynamicResource AccentBrush}" Width="15" Height="15" Margin="0,0,10,0"/>
                        <TextBlock Text="Pairing code regenerated" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Width="30" Height="30" Click="Done_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <fa:IconBlock Icon="Xmark" Foreground="{DynamicResource SubtleTextBrush}" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,18,24,20">
                <TextBlock Text="Give this code to console operators. The previous code no longer works."
                           Foreground="{DynamicResource SubtleTextBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,14"/>

                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,12">
                    <TextBox x:Name="CodeBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" FontSize="24"
                             FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"
                             IsReadOnlyCaretVisible="False"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button x:Name="CopyBtn" Content="Copy" Click="Copy_Click" Width="110" Height="36"
                            Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Done" Click="Done_Click" Width="90" Height="36"
                            Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
