<Window x:Class="PROSCANNERCONT.Views.ScreenshotViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="Screenshot Viewer" 
        Height="600" 
        Width="800"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Background="Black"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ViewerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A0000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main Image Display -->
        <ScrollViewer x:Name="ImageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="Black">
            <Image x:Name="MainImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>

        <!-- Info Panel (Top) -->
        <Border Background="#80000000"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Padding="20"
                x:Name="InfoPanel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Screenshot Info -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TitleText"
                             Text="Screenshot Title"
                             Foreground="White"
                             FontSize="18"
                             FontWeight="Bold"
                             Margin="0,0,0,4"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TimestampText"
                                 Text="Timestamp"
                                 Foreground="#CCFFFFFF"
                                 FontSize="14"
                                 Margin="0,0,15,0"/>

                        <Border x:Name="TypeBadge"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="4"
                                Padding="6,2"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TypeText"
                                     Text="MANUAL"
                                     Foreground="White"
                                     FontSize="10"
                                     FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" 
                          Orientation="Horizontal">
                    <Button Style="{StaticResource ViewerButtonStyle}"
                            Click="SaveButton_Click"
                            ToolTip="Save Screenshot">
                        <fa:IconBlock Icon="FloppyDisk" FontSize="16"/>
                    </Button>

                    <Button Style="{StaticResource ViewerButtonStyle}"
                            Click="DeleteButton_Click"
                            ToolTip="Delete Screenshot">
                        <fa:IconBlock Icon="Trash" FontSize="16"/>
                    </Button>

                    <Button Style="{StaticResource ViewerButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close (ESC)">
                        <fa:IconBlock Icon="Xmark" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Control Panel (Bottom) -->
        <Border Background="#80000000"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Padding="15,10"
                CornerRadius="4"
                Margin="20"
                x:Name="ControlPanel">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ViewerButtonStyle}"
                        Click="ZoomInButton_Click"
                        ToolTip="Zoom In (+)">
                    <fa:IconBlock Icon="Plus" FontSize="14"/>
                </Button>

                <Button Style="{StaticResource ViewerButtonStyle}"
                        Click="ZoomOutButton_Click"
                        ToolTip="Zoom Out (-)">
                    <fa:IconBlock Icon="Minus" FontSize="14"/>
                </Button>

                <Button Style="{StaticResource ViewerButtonStyle}"
                        Click="ZoomFitButton_Click"
                        ToolTip="Fit to Window (0)">
                    <fa:IconBlock Icon="Expand" FontSize="14"/>
                </Button>

                <Button Style="{StaticResource ViewerButtonStyle}"
                        Click="Zoom100Button_Click"
                        ToolTip="Actual Size (1)">
                    <TextBlock Text="1:1" FontSize="12" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>