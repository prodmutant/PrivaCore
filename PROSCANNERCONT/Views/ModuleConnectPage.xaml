<Page x:Class="PROSCANNERCONT.Views.ModuleConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="28">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0"
                            Background="{DynamicResource BackgroundBrush}">
                        <fa:IconBlock x:Name="ModuleIcon" Icon="PuzzlePiece" FontSize="22"
                                      Foreground="{DynamicResource AccentBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" Text="Connect to module"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Connect to the machine running this module."
                                   FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Border Height="1" Background="{DynamicResource BorderBrush}" Opacity="0.6" Margin="0,16"/>

                <!-- Step 1: address -->
                <TextBlock Text="MODULE ADDRESS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="IP / Host" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,3"/>
                        <TextBox x:Name="HostBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,3"/>
                        <TextBox x:Name="PortBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                </Grid>
                <Button x:Name="CheckButton" Content="Check connection" Click="Check_Click"
                        Height="36" Margin="0,12,0,0" Cursor="Hand"
                        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                <!-- Step 2: credentials (revealed after a successful probe) -->
                <StackPanel x:Name="LoginPanel" Visibility="Collapsed" Margin="0,18,0,0">
                    <TextBlock Text="SIGN IN" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Username" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,3"/>
                    <TextBox x:Name="UserBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                             Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="Password" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,10,0,3"/>
                    <PasswordBox x:Name="PassBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="Pairing code" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,10,0,3"/>
                    <PasswordBox x:Name="PairingBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    <CheckBox x:Name="RememberBox" Content="Remember me on this computer for 2 weeks"
                              Foreground="{DynamicResource SubtleTextBrush}" Margin="0,14,0,0"/>
                    <Button x:Name="ConnectButton" Content="Connect" Click="Connect_Click"
                            Height="38" Margin="0,16,0,0" Cursor="Hand" FontWeight="SemiBold"
                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource OnAccentBrush}"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Status -->
                <Border x:Name="StatusBorder" Visibility="Collapsed" Margin="0,16,0,0" CornerRadius="6" Padding="10,8"
                        Background="{DynamicResource BackgroundBrush}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock x:Name="StatusIcon" Icon="CircleInfo" FontSize="13" Margin="0,0,8,0"
                                      VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="Wrap"
                                   FontSize="12" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
