<Page x:Class="PROSCANNERCONT.Views.MiscellaneousPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Background="{DynamicResource BackgroundBrush}"
      Title="Miscellaneous">

    <Page.Resources>

        <!-- Styled Expander: replaces the default ugly arrow with a FontAwesome chevron -->
        <Style x:Key="ModernExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <Border x:Name="HeaderBorder"
                                    Background="{DynamicResource HoverBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Cursor="Hand">
                                <Grid>
                                    <ToggleButton x:Name="HeaderToggle"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="12,10"
                                                  HorizontalContentAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              VerticalAlignment="Center"/>
                                            <fa:IconBlock x:Name="ExpandIcon"
                                                          Grid.Column="1"
                                                          Icon="ChevronDown"
                                                          FontSize="12"
                                                          Foreground="{DynamicResource SubtleTextBrush}"
                                                          VerticalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5">
                                                <fa:IconBlock.RenderTransform>
                                                    <RotateTransform x:Name="ChevronRotation" Angle="0"/>
                                                </fa:IconBlock.RenderTransform>
                                            </fa:IconBlock>
                                        </Grid>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <ContentPresenter x:Name="ExpandContent"
                                              Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandContent" Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="180" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalTextBox" TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="MinimalDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <StackPanel>
                <TextBlock Text="Port Scanner"
                         Foreground="{DynamicResource TextBrush}"
                         FontSize="24"
                         FontWeight="SemiBold"/>
                <TextBlock Text="Comprehensive port scanning, service detection, and CVE vulnerability assessment"
                         Foreground="{DynamicResource TextBrush}"
                         Opacity="0.7"
                         FontSize="14"
                         Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Margin="0,20,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Scanner Section -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,20">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Scanner Header -->
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentBrush}"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="16">
                                <fa:IconBlock Icon="Shield"
                                              Foreground="{DynamicResource OnAccentBrush}"
                                              Width="16"
                                              Height="16"/>
                            </Border>
                            <TextBlock Text="Port &amp; Vulnerability Scanner"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="18"
                                     VerticalAlignment="Center"
                                     Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Target & Port Range -->
                        <Grid Grid.Row="1" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Target IP Address:" 
                                         Foreground="{DynamicResource TextBrush}"
                                         Margin="0,0,0,5"/>
                                <TextBox x:Name="IpTextBox" 
                                       Style="{StaticResource MinimalTextBox}"
                                       Text="192.168.1.1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port Range:" 
                                         Foreground="{DynamicResource TextBrush}"
                                         Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="StartPortTextBox" 
                                           Style="{StaticResource MinimalTextBox}"
                                           Text="1"/>
                                    <TextBlock Grid.Column="1"
                                             Text=" - "
                                             Margin="10,0"
                                             Foreground="{DynamicResource TextBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBox x:Name="EndPortTextBox" 
                                           Grid.Column="2"
                                           Style="{StaticResource MinimalTextBox}"
                                           Text="1024"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Scan Type -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Scan Type:" 
                                         Foreground="{DynamicResource TextBrush}"
                                         Margin="0,0,0,5"/>
                                <ComboBox x:Name="ScanTypeComboBox" 
                                        Style="{StaticResource ComboBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Advanced Options (Expander) -->
                        <Expander Grid.Row="3"
                                  Style="{StaticResource ModernExpander}"
                                  Margin="0,15,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Sliders" FontSize="13"
                                                  Foreground="{DynamicResource AccentBrush}"
                                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Advanced Scan Options"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="14" FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <!-- Service Detection Options -->
                                    <TextBlock Text="Service Detection:" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,10"/>

                                    <CheckBox x:Name="BannerGrabbingCheckBox" 
                                              Content="Banner Grabbing (read service banners)"
                                              Foreground="{DynamicResource TextBrush}"
                                              Style="{StaticResource CheckBoxStyle}"
                                              IsChecked="True"
                                              Margin="0,5"/>

                                    <CheckBox x:Name="VersionDetectionCheckBox" 
                                              Content="Version Detection (identify exact versions)"
                                              Foreground="{DynamicResource TextBrush}"
                                              Style="{StaticResource CheckBoxStyle}"
                                              IsChecked="True"
                                              Margin="0,5"/>

                                    <CheckBox x:Name="AggressiveProbesCheckBox" 
                                              Content="Aggressive Probes (send service-specific packets)"
                                              Foreground="{DynamicResource TextBrush}"
                                              Style="{StaticResource CheckBoxStyle}"
                                              IsChecked="False"
                                              Margin="0,5"
                                              ToolTip="Sends HTTP GET, SMTP EHLO, FTP commands, etc."/>

                                    <Separator Margin="0,15" Background="{DynamicResource BorderBrush}"/>

                                    <!-- Timing Options -->
                                    <TextBlock Text="Scan Timing:" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,10"/>

                                    <ComboBox x:Name="TimingComboBox"
                                              Style="{StaticResource ComboBoxStyle}"
                                              SelectedIndex="3">
                                        <ComboBoxItem Content="Paranoid (very slow, 5min delays)"/>
                                        <ComboBoxItem Content="Sneaky (slow, IDS evasion)"/>
                                        <ComboBoxItem Content="Polite (1 second delay)"/>
                                        <ComboBoxItem Content="Normal (recommended)"/>
                                        <ComboBoxItem Content="Aggressive (fast)"/>
                                        <ComboBoxItem Content="Insane (very fast, may miss results)"/>
                                    </ComboBox>

                                    <Separator Margin="0,15" Background="{DynamicResource BorderBrush}"/>

                                    <!-- IDS Evasion -->
                                    <TextBlock Text="IDS/Firewall Evasion:" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,10"/>

                                    <CheckBox x:Name="RandomizeOrderCheckBox" 
                                              Content="Randomize Port Order"
                                              Foreground="{DynamicResource TextBrush}"
                                              Style="{StaticResource CheckBoxStyle}"
                                              IsChecked="False"
                                              Margin="0,5"
                                              ToolTip="Scan ports in random order to evade pattern detection"/>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- Control Buttons -->
                        <Grid Grid.Row="4" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="StartScanButton" 
                                    Style="{StaticResource MinimalButton}"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    Width="150">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="MagnifyingGlass"
                                                  Margin="0,0,8,0"/>
                                    <TextBlock Text="Start Scan"
                                             Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ExportReportButton"
                                    Grid.Column="2"
                                    Style="{StaticResource MinimalButton}"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    Width="160"
                                    Click="ExportReport_Click"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="FileLines" Margin="0,0,8,0"/>
                                    <TextBlock Text="Export Report" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ClearResultsButton"
                                    Grid.Column="4"
                                    Style="{StaticResource MinimalButton}"
                                    Background="{DynamicResource CriticalBrush}"
                                    Foreground="White"
                                    Width="150"
                                    Click="ClearResultsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Trash"
                                                  Margin="0,0,8,0"/>
                                    <TextBlock Text="Clear Results"
                                             Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Progress Bar -->
                        <Grid Grid.Row="5" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ProgressBar x:Name="ScanProgressBar" 
                                         Height="20" 
                                         Maximum="100" 
                                         Value="0"
                                         Margin="0,0,10,0"
                                         Visibility="Collapsed"/>

                            <TextBlock x:Name="ProgressText"
                                       Grid.Column="1"
                                       Text=""
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"
                                       Visibility="Collapsed"/>
                        </Grid>

                        <!-- Results Grid -->
                        <DataGrid x:Name="ResultsDataGrid" 
                                  Grid.Row="6" 
                                  Style="{StaticResource MinimalDataGrid}"
                                  IsReadOnly="True"
                                  Margin="0,15,0,0"
                                  MinHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IP" 
                                                  Binding="{Binding IPAddress}"
                                                  Width="120"/>
                                <DataGridTextColumn Header="PORT" 
                                                  Binding="{Binding Port}"
                                                  Width="70"/>
                                <DataGridTextColumn Header="PROTOCOL" 
                                                  Binding="{Binding Protocol}"
                                                  Width="90"/>
                                <DataGridTextColumn Header="STATUS" 
                                                  Binding="{Binding Status}"
                                                  Width="100"/>
                                <DataGridTextColumn Header="SERVICE" 
                                                  Binding="{Binding Service}"
                                                  Width="120"/>
                                <DataGridTextColumn Header="VERSION" 
                                                  Binding="{Binding Version}"
                                                  Width="*"/>
                                <DataGridTemplateColumn Header="CVE" 
                                                      Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MinimalButton}"
                                                    Content="View"
                                                    Height="30"
                                                    Padding="15,0"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    Click="CVEViewButton_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>