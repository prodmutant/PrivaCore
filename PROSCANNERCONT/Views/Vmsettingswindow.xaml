<Window x:Class="PROSCANNERCONT.Views.VMSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="VM Settings" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="VMNameText"
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Configure virtual machine settings"
                       FontSize="14"
                       Foreground="{DynamicResource TextBrush}"
                       Opacity="0.7"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Settings -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Memory Section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Memory (RAM)" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock x:Name="MemoryValueText" 
                                       Text="2048 MB"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Slider x:Name="MemorySlider"
                                Minimum="512"
                                Maximum="16384"
                                Value="2048"
                                TickFrequency="512"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MemorySlider_ValueChanged"
                                Margin="0,16,0,0"/>

                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Min: 512 MB"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.6"/>
                            <TextBlock Text="Max: 16384 MB"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.6"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="⚠️ VM must be stopped to change memory"
                                   FontSize="12"
                                   Foreground="{DynamicResource WarningBrush}"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- CPU Section -->
                <Border Style="{StaticResource SectionStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU Cores" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock x:Name="CPUValueText" 
                                       Text="2 Cores"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Slider x:Name="CPUSlider"
                                Minimum="1"
                                Maximum="8"
                                Value="2"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="CPUSlider_ValueChanged"
                                Margin="0,16,0,0"/>

                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Min: 1 Core"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.6"/>
                            <TextBlock Text="Max: 8 Cores"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.6"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="⚠️ VM must be stopped to change CPU"
                                   FontSize="12"
                                   Foreground="{DynamicResource WarningBrush}"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Current Configuration -->
                <Border Style="{StaticResource SectionStyle}"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Opacity="0.1">
                    <StackPanel>
                        <TextBlock Text="Current Configuration" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Opacity="1"/>
                        <TextBlock x:Name="CurrentConfigText"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Opacity="1"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal">
                <fa:IconBlock Icon="CircleInfo" 
                                Foreground="{DynamicResource AccentBrush}"
                                Width="16" Height="16"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                <TextBlock Text="Changes are applied immediately"
                           FontSize="12"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Content="Close"
                        Width="100"
                        Click="CancelButton_Click"
                        Margin="0,0,12,0"/>

                <Button x:Name="ApplyButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Width="120"
                        Click="ApplyButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Check" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Apply Changes"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
