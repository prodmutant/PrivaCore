<Window x:Class="PROSCANNERCONT.Views.CVEDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="CVE Details" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        
>

    <Window.Resources>
        
        <!-- Match the styles from your main window -->
        <Style x:Key="MinimalTextBox" TargetType="TextBox" BasedOn="{StaticResource TextBoxBase}">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style x:Key="MinimalButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CVESeverityBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <!-- Header with drag functionality -->
        <Grid x:Name="HeaderGrid" 
              MouseLeftButtonDown="HeaderGrid_MouseLeftButtonDown"
              Background="Transparent"
              Cursor="SizeAll">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource SeverityCriticalBrush}"
                        Width="40"
                        Height="40"
                        CornerRadius="20">
                    <fa:IconBlock Icon="TriangleExclamation"
                                  Foreground="{DynamicResource OnDangerBrush}"
                                  Width="20"
                                  Height="20"/>
                </Border>
                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ServiceTitleTextBlock"
                             Text="Service Vulnerability Details"
                             Foreground="{DynamicResource TextBrush}" 
                             FontSize="20" 
                             FontWeight="SemiBold"/>
                    <TextBlock x:Name="ServiceInfoTextBlock"
                             Text="Loading service information..."
                             Foreground="{DynamicResource TextBrush}"
                             Opacity="0.7"
                             FontSize="12"
                             Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" 
                    x:Name="CloseButton"
                    Style="{StaticResource MinimalButton}"
                    Width="30"
                    Height="30"
                    Padding="0"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <fa:IconBlock Icon="Xmark"
                              Width="12"
                              Height="12"/>
            </Button>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" 
                      Margin="0,20,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Service Information Card -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,15">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Service Information"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontWeight="SemiBold"
                                 FontSize="16"
                                 Margin="0,0,0,15"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="IP Address:" 
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     Margin="0,0,10,8"/>
                            <TextBlock x:Name="IPAddressTextBlock"
                                     Grid.Column="1"
                                     Text="192.168.1.1"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,20,8"/>

                            <TextBlock Text="Port:" 
                                     Grid.Column="2"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     Margin="0,0,10,8"/>
                            <TextBlock x:Name="PortTextBlock"
                                     Grid.Column="3"
                                     Text="80"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Service:" 
                                     Grid.Row="1"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     Margin="0,0,10,8"/>
                            <TextBlock x:Name="ServiceTextBlock"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Text="HTTP"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,20,8"/>

                            <TextBlock Text="Version:" 
                                     Grid.Row="1"
                                     Grid.Column="2"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     Margin="0,0,10,8"/>
                            <TextBlock x:Name="VersionTextBlock"
                                     Grid.Row="1"
                                     Grid.Column="3"
                                     Text="Apache 2.4.41"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Protocol:" 
                                     Grid.Row="2"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     Margin="0,0,10,0"/>
                            <TextBlock x:Name="ProtocolTextBlock"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Text="TCP"
                                     Foreground="{DynamicResource TextBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- CVE Information Card -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Known Vulnerabilities (CVE)"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="SemiBold"
                                     FontSize="16"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="CVECountTextBlock"
                                     Text="(Loading...)"
                                     Foreground="{DynamicResource TextBrush}"
                                     Opacity="0.7"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Loading indicator -->
                        <StackPanel x:Name="LoadingPanel" 
                                  Grid.Row="1"
                                  Orientation="Horizontal"
                                  HorizontalAlignment="Center"
                                  Margin="0,20">
                            <ProgressBar Width="200"
                                       Height="4"
                                       IsIndeterminate="True"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Searching for vulnerabilities..."
                                     Foreground="{DynamicResource TextBrush}"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- CVE Results -->
                        <ScrollViewer x:Name="CVEScrollViewer"
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    MaxHeight="300"
                                    Visibility="Collapsed">
                            <StackPanel x:Name="CVEListPanel">
                                <!-- CVE items will be added here dynamically -->
                            </StackPanel>
                        </ScrollViewer>

                        <!-- No CVE found message -->
                        <StackPanel x:Name="NoCVEPanel"
                                  Grid.Row="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed">
                            <fa:IconBlock Icon="Shield"
                                          Foreground="{DynamicResource SuccessBrush}"
                                          Width="48"
                                          Height="48"
                                          Margin="0,0,0,15"/>
                            <TextBlock Text="No known vulnerabilities found"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontWeight="Medium"
                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="This service appears to be secure"
                                     Foreground="{DynamicResource TextBrush}"
                                     Opacity="0.7"
                                     FontSize="12"
                                     HorizontalAlignment="Center"
                                     Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Universal networking assessment tool"
                     Foreground="{DynamicResource TextBrush}"
                     Opacity="0.5"
                     FontSize="11"
                     VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    x:Name="RefreshButton"
                    Style="{StaticResource MinimalButton}"
                    Margin="0,0,10,0"
                    Click="RefreshButton_Click">
                <StackPanel Orientation="Horizontal">
                    <fa:IconBlock Icon="ArrowsRotate"
                                  Margin="0,0,5,0"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    x:Name="OKButton"
                    Style="{StaticResource MinimalButton}"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    Click="OKButton_Click">
                <StackPanel Orientation="Horizontal">
                    <fa:IconBlock Icon="Check"
                                  Margin="0,0,5,0"/>
                    <TextBlock Text="OK"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>