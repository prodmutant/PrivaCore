<Page x:Class="PROSCANNERCONT.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:converters="clr-namespace:PROSCANNERCONT.ValueConverters"
      xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
      Background="{DynamicResource BackgroundBrush}"
      Title="Dashboard">

    <Page.Resources>
        <!-- Card Style -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KPI Card Style -->
        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="DashTabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="tb" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Toggle Button Style -->
        <Style x:Key="FilterToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="fb" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="fb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="fb" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clickable finding card style -->
        <Style x:Key="ClickableFindingStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Preset Query Chip Style -->
        <Style x:Key="QueryChipStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cb" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="cb" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="SocDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <!-- Subtle left-to-right accent gradient overlay -->
                <Rectangle IsHitTestVisible="False" Opacity="1">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#14569CD6" Offset="0"/>
                            <GradientStop Color="#00569CD6" Offset="0.6"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Background="{DynamicResource AccentBrush}" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                        <fa:IconBlock Icon="Shield" Foreground="White" Width="16" Height="16"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PrivaCore SOC"
                                   Style="{StaticResource HeaderTextStyle}"
                                   FontSize="16" Margin="0"/>
                        <TextBlock Text="Security Operations Center" FontSize="10" Opacity="0.6"
                                   Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Universal Search Bar -->
                <Border Grid.Column="1"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <fa:IconBlock Icon="MagnifyingGlass" Foreground="{DynamicResource TextBrush}"
                                     Width="14" Height="14" Margin="10,0,6,0" Opacity="0.6"/>
                        <TextBox x:Name="UniversalSearchBox" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontSize="13" VerticalAlignment="Center"
                                 Padding="0,8" CaretBrush="{DynamicResource TextBrush}"
                                 TextChanged="UniversalSearch_TextChanged"
                                 KeyDown="UniversalSearch_KeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search all modules: type:port, ip:192.168., module:ids, severity:critical..."
                                                           Foreground="{DynamicResource TextBrush}" Opacity="0.35" FontSize="12"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource CueBannerBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                                Padding="8,0" Cursor="Hand" Click="UniversalSearchGo_Click">
                            <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BaseButtonStyle}" Width="36" Height="36" Padding="0"
                            Click="RefreshDashboard_Click" ToolTip="Refresh Dashboard" Margin="0,0,6,0">
                        <fa:IconBlock Icon="ArrowsRotate" Foreground="{DynamicResource TextBrush}" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource BaseButtonStyle}" Width="36" Height="36" Padding="0"
                            Click="SecurityCheckButton_Click" ToolTip="Run Security Check">
                        <fa:IconBlock Icon="ShieldHalved" Foreground="{DynamicResource AccentBrush}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
                </Grid><!-- inner content grid -->
            </Grid><!-- outer overlay grid -->
        </Border>

        <!-- ===== TAB BAR ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabOverview" Style="{StaticResource TabButtonStyle}"
                             IsChecked="True" Checked="Tab_Checked" Tag="0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Gauge" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Overview"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="TabAnalytics" Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked" Tag="1" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ChartBar" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Analytics"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="TabActivity" Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked" Tag="2" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ClockRotateLeft" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Activity"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="TabThreats" Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked" Tag="3" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="TriangleExclamation" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Threats"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="TabQuery" Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked" Tag="4" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Terminal" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Query"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- ===== TAB CONTENT ===== -->
        <Grid Grid.Row="2">

            <!-- ============================================================ -->
            <!-- TAB 0: OVERVIEW                                               -->
            <!-- ============================================================ -->
            <Grid x:Name="OverviewTab" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- KPI Cards Row -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Padding="20,16,20,0">
                    <StackPanel Orientation="Horizontal">

                        <!-- Total Scans -->
                        <Border Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource AccentBrush}" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <fa:IconBlock Icon="MagnifyingGlass" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Total Scans" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiTotalScans" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="All scan results" FontSize="10" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Critical Threats -->
                        <Border Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource CriticalBrush}" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <fa:IconBlock Icon="TriangleExclamation" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Critical Threats" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiCriticalThreats" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource CriticalBrush}"/>
                                <TextBlock Text="IDS Critical+High" FontSize="10" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Hosts Discovered -->
                        <Border Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource SuccessBrush}" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <fa:IconBlock Icon="Desktop" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Hosts Discovered" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiHostsDiscovered" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Network devices" FontSize="10" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Open Ports -->
                        <Border Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource WarningBrush}" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <fa:IconBlock Icon="NetworkWired" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Open Ports" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiOpenPorts" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Unique across hosts" FontSize="10" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Traffic Packets -->
                        <Border Style="{StaticResource KpiCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource AccentLightBrush}" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <fa:IconBlock Icon="Wifi" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Traffic Packets" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiTrafficPackets" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Captured packets" FontSize="10" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Security Score -->
                        <Border Style="{StaticResource KpiCardStyle}" Margin="0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border x:Name="SecurityIconBorder" Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF4444" Offset="0"/>
                                                <GradientStop Color="#44FF44" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <fa:IconBlock Icon="Shield" Foreground="White" Width="12" Height="12"/>
                                    </Border>
                                    <TextBlock Text="Security Score" FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel x:Name="SecurityLoadingPanel" Visibility="Collapsed" Orientation="Horizontal">
                                        <fa:IconBlock Icon="CircleNotch" Foreground="{DynamicResource AccentBrush}"
                                                     Width="24" Height="24"
                                                     RenderTransformOrigin="0.5,0.5">
                                            <fa:IconBlock.RenderTransform>
                                                <RotateTransform x:Name="SecuritySpinRotation" CenterX="12" CenterY="12"/>
                                            </fa:IconBlock.RenderTransform>
                                            <fa:IconBlock.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="SecuritySpinRotation"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             From="0" To="360"
                                                                             Duration="0:0:1"
                                                                             RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </fa:IconBlock.Triggers>
                                        </fa:IconBlock>
                                        <TextBlock Text="Scanning..." FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel x:Name="SecurityScorePanel">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="SecurityScoreText" Text="--" FontSize="32" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <emoji:TextBlock x:Name="SecurityEmoji" Text="😐" FontSize="22"
                                                            Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="SecurityRiskLevelText" Text="Not Scanned" FontSize="10"
                                                   Opacity="0.6" Foreground="{DynamicResource TextBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="LastScanText" Text="Click shield to start" FontSize="10"
                                           Opacity="0.5" Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Overview Body: Widget Area -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Widget area header -->
                    <Grid Margin="20,10,20,8">
                        <TextBlock Text="Overview" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                        <Button HorizontalAlignment="Right" Click="CustomizeDashboard_Click"
                                Style="{StaticResource BaseButtonStyle}" Height="30" Padding="12,0" Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Plus" Width="12" Height="12"
                                              Foreground="{DynamicResource TextBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Add Widgets" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Security status bar -->
                    <Border x:Name="SecurityStatusStrip" Grid.Row="1"
                            Margin="20,0,20,8" Height="36"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,0"/>

                    <!-- Widget canvas -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20,0,20,20">
                        <Canvas x:Name="WidgetsPanel"/>
                    </ScrollViewer>
                </Grid>

                <!-- ══ Hidden legacy named elements for code-behind compatibility ══ -->
                <Grid Visibility="Collapsed">
                    <!-- Module status list used by RefreshModuleStatus() -->
                    <ItemsControl x:Name="ModuleStatusList">
                        <!-- same template as before, hidden -->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        CornerRadius="6" Margin="0,0,0,8" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusDot}" FontSize="14"
                                                   Foreground="{Binding DotColor}" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ModuleName}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="{Binding LastActivity}" FontSize="10" Opacity="0.6"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="10"
                                                   Foreground="{Binding DotColor}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Recent scan results used by RefreshRecentFindings() -->
                    <ItemsControl x:Name="RecentVulnerabilities"/>
                    <!-- Calendar elements used by CalendarButton_Click / ScanHistoryCalendar_SelectedDatesChanged -->
                    <Button x:Name="CalendarButton" Click="CalendarButton_Click"/>
                    <Popup x:Name="CalendarPopup"
                           PlacementTarget="{Binding ElementName=CalendarButton}"
                           Placement="Bottom" StaysOpen="False">
                        <Border Background="{DynamicResource BackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="10">
                            <Calendar x:Name="ScanHistoryCalendar"
                                      SelectedDatesChanged="ScanHistoryCalendar_SelectedDatesChanged"
                                      Background="Transparent" BorderThickness="0"/>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ══ DEAD CODE BELOW - kept so XAML parser finds all old named elements ══ -->
                <Grid Visibility="Collapsed" IsHitTestVisible="False">
                    <!-- Module Status Panel (kept for x:Name resolution) -->
                    <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,12,0">
                        <DockPanel Margin="16">
                            <TextBlock DockPanel.Dock="Top" Text="Module Status" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="_ModuleStatusListUnused">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BackgroundBrush}"
                                                    CornerRadius="6" Margin="0,0,0,8" Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StatusDot}" FontSize="14"
                                                               Foreground="{Binding DotColor}" VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding ModuleName}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="{Binding LastActivity}" FontSize="10" Opacity="0.6"
                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="10"
                                                               Foreground="{Binding DotColor}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Recent Findings -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardCardStyle}">
                        <DockPanel Margin="16">
                            <!-- Header -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Recent Findings" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Click to expand details" FontSize="10"
                                               Foreground="{DynamicResource AccentBrush}" Opacity="0.8" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource BaseButtonStyle}"
                                            Width="36" Height="36" Padding="0"
                                            Click="CalendarButton_Click"
                                            ToolTip="View scan history by date">
                                        <fa:IconBlock Icon="Calendar" Foreground="{DynamicResource TextBrush}" Width="14" Height="14"/>
                                    </Button>
                                    <!-- Calendar Popup -->
                                    <Popup PlacementTarget="{Binding ElementName=CalendarButton}"
                                           Placement="Bottom" StaysOpen="False">
                                        <Border Background="{DynamicResource BackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="10">
                                            <Calendar SelectedDatesChanged="ScanHistoryCalendar_SelectedDatesChanged"
                                                      Background="Transparent" BorderThickness="0"/>
                                        </Border>
                                    </Popup>
                                </StackPanel>
                            </Grid>

                            <!-- Findings List -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="CardBorder"
                                                    Margin="0,0,0,10"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="ExpandCard_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Collapsed row -->
                                                    <Grid Grid.Row="0" Margin="12,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Good">
                                                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                            <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                            <Setter Property="Fill" Value="{DynamicResource CriticalBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Type}" FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{DynamicResource TextBrush}"/>
                                                            <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7"
                                                                       Foreground="{DynamicResource TextBrush}"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                                   FontSize="10" Opacity="0.5"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   VerticalAlignment="Center" Margin="8,0,8,0"/>
                                                        <fa:IconBlock Grid.Column="3" x:Name="ExpandArrow"
                                                                     Icon="ChevronDown" Width="10" Height="10"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     VerticalAlignment="Center"
                                                                     RenderTransformOrigin="0.5,0.5">
                                                            <fa:IconBlock.RenderTransform>
                                                                <RotateTransform x:Name="ArrowRotation" Angle="0"/>
                                                            </fa:IconBlock.RenderTransform>
                                                        </fa:IconBlock>
                                                    </Grid>

                                                    <!-- Expanded content -->
                                                    <Border x:Name="ExpandedContent" Grid.Row="1"
                                                            Background="{DynamicResource BackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,1,0,0"
                                                            Visibility="Collapsed">
                                                        <Grid Margin="12,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Thumbnail -->
                                                            <Border Width="92" Height="62"
                                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1" CornerRadius="4" Margin="0,0,10,0">
                                                                <Grid>
                                                                    <Image Source="{Binding PageSnapshot}" Stretch="Uniform">
                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasSnapshot}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Image.Style>
                                                                    </Image>
                                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                        <StackPanel.Style>
                                                                            <Style TargetType="StackPanel">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasSnapshot}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </StackPanel.Style>
                                                                        <fa:IconBlock Icon="Image" Width="18" Height="18"
                                                                                     Foreground="{DynamicResource TextBrush}" Opacity="0.3"/>
                                                                        <TextBlock Text="No Preview" FontSize="9" Opacity="0.5"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Details -->
                                                            <StackPanel Grid.Column="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="60"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition/>
                                                                        <RowDefinition/>
                                                                        <RowDefinition/>
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Text="Time:" FontSize="10" FontWeight="SemiBold" Opacity="0.6"
                                                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Timestamp, StringFormat='{}{0:MMM dd HH:mm}'}"
                                                                               FontSize="10" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                                                                    <TextBlock Grid.Row="1" Text="Source:" FontSize="10" FontWeight="SemiBold" Opacity="0.6"
                                                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PageType}"
                                                                               FontSize="10" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,3"/>
                                                                    <TextBlock Grid.Row="2" Text="Status:" FontSize="10" FontWeight="SemiBold" Opacity="0.6"
                                                                               Foreground="{DynamicResource TextBrush}"/>
                                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Good">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource CriticalBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                                    <Button Content="Navigate" Height="24" Padding="8,2"
                                                                            Margin="0,0,6,0"
                                                                            Background="{DynamicResource AccentBrush}"
                                                                            Foreground="White" BorderThickness="0"
                                                                            Click="NavigateToPage_Click" Tag="{Binding}">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PageType}" Value="">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PageType}" Value="Dashboard">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PageType}" Value="{x:Null}">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="Ask AI" Style="{StaticResource BaseButtonStyle}"
                                                                            Height="24" Padding="8,2"
                                                                            Click="AskAssistant_Click" Tag="{Binding}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TAB 1: ANALYTICS                                              -->
            <!-- ============================================================ -->
            <Grid x:Name="AnalyticsTab" Visibility="Collapsed" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Chart 1: Activity Last 7 Days -->
                <Border Style="{StaticResource DashboardCardStyle}" Grid.Row="0" Grid.Column="0">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top" Text="Activity — Last 7 Days"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                        <Canvas x:Name="Chart7Days"
                                SizeChanged="ChartCanvas_SizeChanged"
                                Loaded="ChartCanvas_Loaded"/>
                    </DockPanel>
                </Border>

                <!-- Chart 2: Scan Type Distribution -->
                <Border Style="{StaticResource DashboardCardStyle}" Grid.Row="0" Grid.Column="2">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top" Text="Scan Type Distribution"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                        <Canvas x:Name="ChartScanTypes"
                                SizeChanged="ChartCanvas_SizeChanged"
                                Loaded="ChartCanvas_Loaded"/>
                    </DockPanel>
                </Border>

                <!-- Chart 3: Threat Severity -->
                <Border Style="{StaticResource DashboardCardStyle}" Grid.Row="2" Grid.Column="0">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top" Text="Threat Severity Breakdown"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                        <Canvas x:Name="ChartThreatSeverity"
                                SizeChanged="ChartCanvas_SizeChanged"
                                Loaded="ChartCanvas_Loaded"/>
                    </DockPanel>
                </Border>

                <!-- Chart 4: Protocol Mix -->
                <Border Style="{StaticResource DashboardCardStyle}" Grid.Row="2" Grid.Column="2">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top" Text="Protocol Mix (Traffic)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                        <Canvas x:Name="ChartProtocols"
                                SizeChanged="ChartCanvas_SizeChanged"
                                Loaded="ChartCanvas_Loaded"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ============================================================ -->
            <!-- TAB 2: ACTIVITY                                               -->
            <!-- ============================================================ -->
            <Grid x:Name="ActivityTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter Bar -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Module filter toggles -->
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="FilterAll" Style="{StaticResource FilterToggleStyle}"
                                         IsChecked="True" GroupName="ActivityFilter"
                                         Content="All" Checked="ActivityFilter_Checked" Tag="All"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="Port Scanner" Checked="ActivityFilter_Checked" Tag="Port Scanner"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="Network Discovery" Checked="ActivityFilter_Checked" Tag="Network Discovery"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="Traffic Analysis" Checked="ActivityFilter_Checked" Tag="Traffic Analysis"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="IDS" Checked="ActivityFilter_Checked" Tag="IDS"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="Vulnerability" Checked="ActivityFilter_Checked" Tag="Vulnerability"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ActivityFilter"
                                         Content="Security" Checked="ActivityFilter_Checked" Tag="Security"/>
                        </StackPanel>

                        <!-- Search + calendar row -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Icon="MagnifyingGlass" Foreground="{DynamicResource TextBrush}"
                                                 Width="12" Height="12" Margin="8,0,4,0" Opacity="0.5"/>
                                    <TextBox x:Name="ActivitySearchBox" Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextBrush}" FontSize="12"
                                             VerticalAlignment="Center" Padding="0,7"
                                             CaretBrush="{DynamicResource TextBrush}"
                                             TextChanged="ActivitySearch_TextChanged"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Activity Feed -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl x:Name="ActivityFeedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="6"
                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderThickness="3,0,0,0"
                                        BorderBrush="{Binding ModuleColor}">
                                    <Grid Margin="12,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Module badge -->
                                        <Border Width="48" Height="20" CornerRadius="3"
                                                Background="{Binding ModuleColor}" Margin="0,0,10,0"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding ModuleShort}" FontSize="9" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- Content -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Right side -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding TimeText}" FontSize="10" Opacity="0.6"
                                                       Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Right"/>
                                            <Border CornerRadius="3" Padding="5,2" Margin="0,4,0,0"
                                                    Background="{Binding StatusBrush}" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Status}" FontSize="9" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================ -->
            <!-- TAB 3: THREATS                                                -->
            <!-- ============================================================ -->
            <Grid x:Name="ThreatsTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter bar -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ThreatFilterAll" Style="{StaticResource FilterToggleStyle}"
                                         IsChecked="True" GroupName="ThreatFilter"
                                         Content="All" Checked="ThreatFilter_Checked" Tag="All"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ThreatFilter"
                                         Content="Critical" Checked="ThreatFilter_Checked" Tag="Critical"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ThreatFilter"
                                         Content="High" Checked="ThreatFilter_Checked" Tag="High"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ThreatFilter"
                                         Content="Medium" Checked="ThreatFilter_Checked" Tag="Medium"/>
                            <RadioButton Style="{StaticResource FilterToggleStyle}" GroupName="ThreatFilter"
                                         Content="Low" Checked="ThreatFilter_Checked" Tag="Low"/>
                        </StackPanel>
                        <TextBlock x:Name="ThreatCountText" Grid.Column="2"
                                   FontSize="12" Opacity="0.7"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Threats DataGrid -->
                <DataGrid x:Name="ThreatsGrid" Grid.Row="1"
                          Style="{StaticResource SocDataGridStyle}"
                          Margin="16"
                          ItemsSource="{Binding ThreatsView}">

                    <!-- Row-level severity coloring -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="MinHeight" Value="34"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeverityText}" Value="Critical">
                                    <Setter Property="Background" Value="{DynamicResource SeverityCriticalBgBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SeverityText}" Value="High">
                                    <Setter Property="Background" Value="{DynamicResource SeverityHighBgBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SeverityText}" Value="Medium">
                                    <Setter Property="Background" Value="{DynamicResource SeverityMediumBgBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SeverityText}" Value="Low">
                                    <Setter Property="Background" Value="{DynamicResource SeverityLowBgBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="0,0,0,1"
                                                BorderBrush="{DynamicResource BorderBrush}">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="36"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Severity" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="5,2" Margin="2"
                                            Background="{Binding SeverityBrush}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SeverityText}" FontSize="10" Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="140"/>
                        <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="80"/>
                        <DataGridTemplateColumn Header="Ack" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <fa:IconBlock Width="12" Height="12" HorizontalAlignment="Center">
                                        <fa:IconBlock.Style>
                                            <Style TargetType="fa:IconBlock">
                                                <Setter Property="Icon" Value="CircleXmark"/>
                                                <Setter Property="Foreground" Value="{DynamicResource CriticalBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                                                        <Setter Property="Icon" Value="CircleCheck"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </fa:IconBlock.Style>
                                    </fa:IconBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ============================================================ -->
            <!-- TAB 4: QUERY                                                  -->
            <!-- ============================================================ -->
            <Grid x:Name="QueryTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Query Input Area -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Search &amp; Query" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>

                        <!-- Query Box -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Margin="0,0,8,0">
                                <TextBox x:Name="QueryInputBox"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextBrush}"
                                         FontFamily="Consolas, Courier New, monospace"
                                         FontSize="13" Padding="10,8"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         KeyDown="QueryInput_KeyDown"/>
                            </Border>
                            <Button Grid.Column="1" Style="{StaticResource BaseButtonStyle}"
                                    Height="36" Padding="16,0" Margin="0,0,6,0"
                                    Click="QueryRun_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Play" Width="11" Height="11" Margin="0,0,6,0"/>
                                    <TextBlock Text="Run"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Style="{StaticResource BaseButtonStyle}"
                                    Height="36" Padding="12,0"
                                    Click="QueryClear_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Xmark" Width="11" Height="11" Margin="0,0,6,0"/>
                                    <TextBlock Text="Clear"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="Use prefixes: type:port  status:error  module:ids  severity:critical  ip:192.168.1.1"
                                   FontSize="11" Opacity="0.5" Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Preset Chips -->
                        <WrapPanel>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Critical Threats Today"
                                    Click="QueryChip_Click" Tag="severity:critical module:ids"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Error Status Scans"
                                    Click="QueryChip_Click" Tag="status:error"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="IDS Alerts Last Hour"
                                    Click="QueryChip_Click" Tag="module:ids"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Open Port Findings"
                                    Click="QueryChip_Click" Tag="type:port"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Network Discovery"
                                    Click="QueryChip_Click" Tag="module:network"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Traffic Captures"
                                    Click="QueryChip_Click" Tag="type:traffic"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="Security Checks"
                                    Click="QueryChip_Click" Tag="type:security"/>
                            <Button Style="{StaticResource QueryChipStyle}" Content="All Scans Today"
                                    Click="QueryChip_Click" Tag="today"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Query Results -->
                <DockPanel Grid.Row="1" Margin="16">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Results: " FontSize="12" Opacity="0.7"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="QueryResultCountText" Text="0" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" items found" FontSize="12" Opacity="0.7"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid x:Name="QueryResultsGrid"
                              Style="{StaticResource SocDataGridStyle}"
                              ItemsSource="{Binding QueryResults}">

                        <!-- Row coloring by status -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="32"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                        <Setter Property="Background" Value="{DynamicResource SeverityCriticalBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource SeverityHighBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Good">
                                        <Setter Property="Background" Value="{DynamicResource SeverityLowBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Critical">
                                        <Setter Property="Background" Value="{DynamicResource SeverityCriticalBgBrush}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="140"/>
                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="110"/>
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="5,2" Margin="2"
                                                Background="{Binding StatusColor}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="160"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

        </Grid><!-- end tab content grid -->

        <!-- Speed-test preserved controls (hidden) — placed in row 2 so they never overlay the header -->
        <Grid Grid.Row="2" Visibility="Collapsed" Panel.ZIndex="-1">
            <TextBlock x:Name="SpeedText" Text="-- Mbps"/>
            <TextBlock x:Name="StatusText" Text="Click to Test Speed"/>
            <Button x:Name="TestSpeedButton" Click="TestSpeedButton_Click"/>
            <ProgressBar x:Name="ScanProgressBar"/>
        </Grid>

    </Grid>
</Page>
