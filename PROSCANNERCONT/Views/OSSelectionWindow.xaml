<Window x:Class="PROSCANNERCONT.Views.OSSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deploy Honeypot" 
        Height="750" Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SecondaryBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="ConfigSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Height" Value="24"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🍯 Deploy Honeypot" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock x:Name="SystemSpecsText"
                       Text="Detecting system specifications..."
                       FontSize="12"
                       Foreground="#808080"
                       Margin="0,4,0,0"/>
            <TextBlock Text="Configure and deploy your honeypot virtual machine"
                       FontSize="14"
                       Foreground="#CCCCCC"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Configuration Panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- OS Selection -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Operating System" Style="{StaticResource LabelStyle}"/>

                        <ComboBox x:Name="OSTemplateComboBox"
                                  Height="60"
                                  FontSize="14"
                                  Background="{DynamicResource SecondaryBackgroundBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  SelectionChanged="OSTemplate_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Icon}"
                                                   FontSize="24"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="#CCCCCC"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- OS Details -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock x:Name="OSCategoryText"
                                           Text="Category: Lightweight"
                                           FontSize="12"
                                           Foreground="#4EC9B0"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="OSFeaturesText"
                                           Text="Features loading..."
                                           FontSize="11"
                                           Foreground="#CCCCCC"
                                           TextWrapping="Wrap"/>

                                <TextBlock x:Name="ISODownloadLink"
                                           Text="📥 Download ISO"
                                           FontSize="11"
                                           Foreground="#007ACC"
                                           TextDecorations="Underline"
                                           Cursor="Hand"
                                           Margin="0,8,0,0"
                                           MouseLeftButtonDown="ISODownloadLink_Click"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- VM Name -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Honeypot Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="VMNameTextBox"
                                 Background="{DynamicResource SecondaryBackgroundBrush}"
                                 Foreground="White"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="12"
                                 FontSize="14"
                                 Height="40"
                                 TextChanged="VMNameTextBox_TextChanged"/>
                        <TextBlock x:Name="VMNameError"
                                   Text="⚠ Honeypot name is required"
                                   Foreground="#F48771"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Installation Source -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Installation Source" Style="{StaticResource LabelStyle}"/>

                        <!-- Base Image Option -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,12"
                                x:Name="BaseImageOption">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <RadioButton x:Name="UseBaseImageRadio"
                                             Grid.Column="0"
                                             GroupName="InstallSource"
                                             IsChecked="True"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             Checked="InstallationSource_Changed"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="⚡ Use Pre-built Base Image (Instant)"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock x:Name="BaseImageStatusText"
                                               Text="Base image available - VM will be ready instantly"
                                               FontSize="12"
                                               Foreground="#4EC9B0"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="✓ Recommended"
                                           FontSize="12"
                                           Foreground="#4EC9B0"
                                           VerticalAlignment="Center"
                                           x:Name="BaseImageRecommendedLabel"/>
                            </Grid>
                        </Border>

                        <!-- ISO Option -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <RadioButton x:Name="UseISORadio"
                                                 Grid.Column="0"
                                                 GroupName="InstallSource"
                                                 IsChecked="False"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,12,0"
                                                 Checked="InstallationSource_Changed"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="💿 Install from ISO File"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock Text="Manual installation required (~5-10 minutes)"
                                                   FontSize="12"
                                                   Foreground="#CCCCCC"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ISO Browser -->
                                <StackPanel x:Name="ISOBrowserPanel" 
                                            Margin="28,12,0,0"
                                            Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="ISOPathTextBox"
                                                 Grid.Column="0"
                                                 Background="{DynamicResource HoverBrush}"
                                                 Foreground="White"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="10"
                                                 FontSize="13"
                                                 Height="36"
                                                 IsReadOnly="True"
                                                 Text="No ISO file selected"
                                                 Margin="0,0,8,0"/>

                                        <Button Grid.Column="1"
                                                Content="📁 Browse"
                                                Click="BrowseISO_Click"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="White"
                                                Padding="15,8"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Height="36"/>
                                    </Grid>

                                    <TextBlock x:Name="ISOValidationText"
                                               Text="✓ Valid ISO file selected"
                                               FontSize="12"
                                               Foreground="#4EC9B0"
                                               Margin="0,8,0,0"
                                               Visibility="Collapsed"/>

                                    <TextBlock x:Name="ISOErrorText"
                                               Text="⚠ Please select a valid ISO file"
                                               FontSize="12"
                                               Foreground="#F48771"
                                               Margin="0,8,0,0"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Memory -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Memory (RAM)" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="MemoryValueText" 
                                       Text="256 MB"
                                       Foreground="#007ACC"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Slider x:Name="MemorySlider"
                                Style="{StaticResource SliderStyle}"
                                Minimum="128"
                                Maximum="2048"
                                Value="256"
                                TickFrequency="128"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MemorySlider_ValueChanged"
                                Margin="0,8,0,0"/>

                        <Grid Margin="0,4,0,0">
                            <TextBlock x:Name="MemoryMinText" 
                                       Text="Min: 128 MB"
                                       FontSize="11"
                                       Foreground="#808080"/>
                            <TextBlock x:Name="MemoryRecommendedText"
                                       Text="Recommended: 256 MB"
                                       FontSize="11"
                                       Foreground="#007ACC"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="MemoryMaxText"
                                       Text="Max: 2048 MB"
                                       FontSize="11"
                                       Foreground="#808080"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CPU -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU Cores" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="CPUValueText" 
                                       Text="1 Core"
                                       Foreground="#007ACC"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Slider x:Name="CPUSlider"
                                Style="{StaticResource SliderStyle}"
                                Minimum="1"
                                Maximum="4"
                                Value="1"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="CPUSlider_ValueChanged"
                                Margin="0,8,0,0"/>

                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="Min: 1 Core"
                                       FontSize="11"
                                       Foreground="#808080"/>
                            <TextBlock x:Name="CPURecommendedText"
                                       Text="Recommended: 1 Core"
                                       FontSize="11"
                                       Foreground="#007ACC"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CPUMaxText"
                                       Text="Max: 4 Cores"
                                       FontSize="11"
                                       Foreground="#808080"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Storage -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Storage" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="StorageValueText" 
                                       Text="5 GB"
                                       Foreground="#007ACC"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Slider x:Name="StorageSlider"
                                Style="{StaticResource SliderStyle}"
                                Minimum="2"
                                Maximum="50"
                                Value="5"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                ValueChanged="StorageSlider_ValueChanged"
                                Margin="0,8,0,0"/>

                        <Grid Margin="0,4,0,0">
                            <TextBlock x:Name="StorageMinText"
                                       Text="Min: 2 GB"
                                       FontSize="11"
                                       Foreground="#808080"/>
                            <TextBlock x:Name="StorageRecommendedText"
                                       Text="Recommended: 5 GB"
                                       FontSize="11"
                                       Foreground="#007ACC"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="StorageMaxText"
                                       Text="Max: 50 GB"
                                       FontSize="11"
                                       Foreground="#808080"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Network -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Network Type" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="NetworkTypeComboBox"
                                  Height="40"
                                  FontSize="14"
                                  Background="{DynamicResource SecondaryBackgroundBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="NAT (Recommended - Isolated)" IsSelected="True"/>
                            <ComboBoxItem Content="Bridged (Direct Network Access)"/>
                            <ComboBoxItem Content="Internal (VM to VM only)"/>
                            <ComboBoxItem Content="Private (Completely Isolated)"/>
                        </ComboBox>

                        <TextBlock x:Name="NetworkDescriptionText"
                                   Text="💡 NAT isolates the honeypot from your network while allowing outbound internet access"
                                   FontSize="12"
                                   Foreground="#808080"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- VM Generation -->
                <Border Style="{StaticResource ConfigSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="VM Generation" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Generation 1 -->
                            <Border Grid.Column="0"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="0,0,8,0"
                                    x:Name="Gen1Border">
                                <StackPanel>
                                    <Grid>
                                        <RadioButton x:Name="Gen1Radio"
                                                     GroupName="Generation"
                                                     IsChecked="True"
                                                     VerticalAlignment="Top"
                                                     Checked="Generation_Changed"/>
                                        <TextBlock Text="Generation 1"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="25,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="BIOS-based"
                                               FontSize="12"
                                               Foreground="#4EC9B0"
                                               Margin="25,4,0,8"/>
                                    <TextBlock Text="✓ Best for Linux"
                                               FontSize="11"
                                               Foreground="#CCCCCC"
                                               Margin="25,0,0,2"/>
                                    <TextBlock Text="✓ More compatible"
                                               FontSize="11"
                                               Foreground="#CCCCCC"
                                               Margin="25,0,0,2"/>
                                </StackPanel>
                            </Border>

                            <!-- Generation 2 -->
                            <Border Grid.Column="1"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="8,0,0,0"
                                    x:Name="Gen2Border">
                                <StackPanel>
                                    <Grid>
                                        <RadioButton x:Name="Gen2Radio"
                                                     GroupName="Generation"
                                                     IsChecked="False"
                                                     VerticalAlignment="Top"
                                                     Checked="Generation_Changed"/>
                                        <TextBlock Text="Generation 2"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="25,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="UEFI-based"
                                               FontSize="12"
                                               Foreground="#C586C0"
                                               Margin="25,4,0,8"/>
                                    <TextBlock Text="• Modern firmware"
                                               FontSize="11"
                                               Foreground="#CCCCCC"
                                               Margin="25,0,0,2"/>
                                    <TextBlock Text="⚠ May need config"
                                               FontSize="11"
                                               Foreground="#F48771"
                                               Margin="25,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="GenerationRecommendationText"
                                   Text="💡 Generation 1 is recommended for most Linux distributions"
                                   FontSize="12"
                                   Foreground="#4EC9B0"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Text="Ready to deploy"
                       FontSize="13"
                       Foreground="#4EC9B0"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="100"
                        Height="40"
                        Background="{DynamicResource BorderBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CancelButton_Click"
                        Margin="0,0,12,0"/>

                <Button x:Name="DeployButton"
                        Content="🚀 Deploy Honeypot"
                        Width="180"
                        Height="40"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Click="DeployButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
