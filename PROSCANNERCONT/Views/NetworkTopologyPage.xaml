<Page x:Class="PROSCANNERCONT.Views.NetworkTopologyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:PROSCANNERCONT.Views"
      Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <!-- Device Node Style -->
        <Style x:Key="DeviceNodeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#007ACC" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Connection Line Style -->
        <Style x:Key="ConnectionLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Panel -->
        <Border Grid.Row="0" 
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title and Stats -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Network Topology Map" 
                               Style="{StaticResource HeaderTextStyle}"
                               Margin="0,0,0,10"/>

                    <!-- Manual Scan Configuration -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="?? Scan Config:" 
                                      Foreground="{DynamicResource AccentBrush}"
                                      FontWeight="SemiBold"
                                      VerticalAlignment="Center"
                                      Margin="0,0,15,0"/>

                            <TextBlock Text="IP Range:" 
                                      Foreground="{DynamicResource TextBrush}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>
                            <TextBox x:Name="StartIPTextBox"
                                    Text="192.168.1.1"
                                    Width="110"
                                    Height="28"
                                    Padding="5"
                                    Margin="0,0,5,0"
                                    VerticalContentAlignment="Center"/>
                            <TextBlock Text="to" 
                                      Foreground="{DynamicResource TextBrush}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>
                            <TextBox x:Name="EndIPTextBox"
                                    Text="192.168.1.254"
                                    Width="110"
                                    Height="28"
                                    Padding="5"
                                    Margin="0,0,15,0"
                                    VerticalContentAlignment="Center"/>

                            <TextBlock Text="Subnet Mask:" 
                                      Foreground="{DynamicResource TextBrush}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>
                            <TextBox x:Name="SubnetMaskTextBox"
                                    Text="255.255.255.0"
                                    Width="110"
                                    Height="28"
                                    Padding="5"
                                    Margin="0,0,10,0"
                                    VerticalContentAlignment="Center"/>

                            <CheckBox x:Name="AutoDetectCheckBox"
                                     Content="Auto-detect"
                                     IsChecked="True"
                                     Foreground="{DynamicResource TextBrush}"
                                     VerticalAlignment="Center"
                                     Margin="10,0,0,0"
                                     Checked="AutoDetectCheckBox_Changed"
                                     Unchecked="AutoDetectCheckBox_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Summary Stats -->
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Total Devices" 
                                          Foreground="{DynamicResource TextBrush}" 
                                          FontSize="11" 
                                          Opacity="0.7"/>
                                <TextBlock x:Name="TotalDevicesText" 
                                          Text="0" 
                                          Foreground="{DynamicResource AccentBrush}" 
                                          FontSize="24" 
                                          FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Routers" 
                                          Foreground="{DynamicResource TextBrush}" 
                                          FontSize="11" 
                                          Opacity="0.7"/>
                                <TextBlock x:Name="RoutersCountText" 
                                          Text="0" 
                                          Foreground="{DynamicResource SuccessBrush}" 
                                          FontSize="24" 
                                          FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Access Points" 
                                          Foreground="{DynamicResource TextBrush}" 
                                          FontSize="11" 
                                          Opacity="0.7"/>
                                <TextBlock x:Name="AccessPointsCountText" 
                                          Text="0" 
                                          Foreground="{DynamicResource WarningBrush}" 
                                          FontSize="24" 
                                          FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Endpoints" 
                                          Foreground="{DynamicResource TextBrush}" 
                                          FontSize="11" 
                                          Opacity="0.7"/>
                                <TextBlock x:Name="EndpointsCountText" 
                                          Text="0" 
                                          Foreground="#FF9C27B0" 
                                          FontSize="24" 
                                          FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Mobile Devices" 
                                          Foreground="{DynamicResource TextBrush}" 
                                          FontSize="11" 
                                          Opacity="0.7"/>
                                <TextBlock x:Name="MobileDevicesCountText" 
                                          Text="0" 
                                          Foreground="#FF00BCD4" 
                                          FontSize="24" 
                                          FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ScanButton" 
                            Content="?? Scan Network" 
                            Style="{StaticResource SettingsButtonStyle}"
                            Click="ScanButton_Click"
                            Width="150"
                            Height="40"
                            Margin="5"/>

                    <Button x:Name="RefreshButton" 
                            Content="?? Refresh" 
                            Style="{StaticResource BaseButtonStyle}"
                            Click="RefreshButton_Click"
                            Width="120"
                            Height="40"
                            Margin="5"/>

                    <Button x:Name="ResetViewButton" 
                            Content="? Reset View" 
                            Style="{StaticResource BaseButtonStyle}"
                            Click="ResetViewButton_Click"
                            Width="120"
                            Height="40"
                            Margin="5"/>

                    <Button x:Name="ExportButton" 
                            Content="?? Export" 
                            Style="{StaticResource BaseButtonStyle}"
                            Click="ExportButton_Click"
                            Width="120"
                            Height="40"
                            Margin="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Topology Canvas Area -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource BackgroundBrush}"
                    ClipToBounds="True">
                <Grid>
                    <!-- Background Grid Pattern -->
                    <Canvas x:Name="BackgroundCanvas" 
                            Background="{DynamicResource BackgroundBrush}"
                            ClipToBounds="True">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BackgroundScaleTransform" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="BackgroundTranslateTransform" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>

                    <!-- Main Topology Canvas -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent">
                        <Canvas x:Name="TopologyCanvas" 
                                Width="3000" 
                                Height="2000"
                                Background="Transparent"
                                MouseLeftButtonDown="TopologyCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="TopologyCanvas_MouseLeftButtonUp"
                                MouseMove="TopologyCanvas_MouseMove"
                                MouseWheel="TopologyCanvas_MouseWheel">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="CanvasTranslateTransform" X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                    </ScrollViewer>

                    <!-- Loading Overlay -->
                    <Border x:Name="LoadingOverlay"
                            Background="{DynamicResource OverlayBackgroundBrush}"
                            Visibility="Collapsed"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="LoadingText"
                                      Text="Scanning Network..."
                                      Foreground="{DynamicResource TextBrush}"
                                      FontSize="20"
                                      FontWeight="SemiBold"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,20"/>

                            <ProgressBar x:Name="LoadingProgressBar"
                                        Width="300"
                                        Height="8"
                                        IsIndeterminate="True"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Background="{DynamicResource SecondaryBackgroundBrush}"/>

                            <TextBlock x:Name="LoadingDetailText"
                                      Text="Discovering devices..."
                                      Foreground="{DynamicResource TextSecondary}"
                                      FontSize="14"
                                      HorizontalAlignment="Center"
                                      Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Zoom Controls -->
                    <StackPanel VerticalAlignment="Bottom" 
                               HorizontalAlignment="Right" 
                               Margin="20">
                        <Border Style="{StaticResource CardStyle}" Padding="5">
                            <StackPanel>
                                <Button Content="+" 
                                       Width="40" 
                                       Height="40" 
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Click="ZoomIn_Click"
                                       Style="{StaticResource BaseButtonStyle}"
                                       Margin="0,0,0,5"/>

                                <TextBlock x:Name="ZoomLevelText" 
                                          Text="100%" 
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          HorizontalAlignment="Center"
                                          Margin="0,5"/>

                                <Button Content="-" 
                                       Width="40" 
                                       Height="40" 
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Click="ZoomOut_Click"
                                       Style="{StaticResource BaseButtonStyle}"
                                       Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Legend -->
                    <Border VerticalAlignment="Top" 
                           HorizontalAlignment="Left" 
                           Style="{StaticResource CardStyle}"
                           Margin="20"
                           Padding="15">
                        <StackPanel>
                            <TextBlock Text="Legend" 
                                      Foreground="{DynamicResource TextBrush}" 
                                      FontWeight="SemiBold" 
                                      FontSize="14"
                                      Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="12" Height="12" Fill="#FF00BCD4" Margin="0,0,8,0"/>
                                <TextBlock Text="Router/Gateway" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="12" Height="12" Fill="#FFFF9800" Margin="0,0,8,0"/>
                                <TextBlock Text="Access Point" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="12" Height="12" Fill="#FF4CAF50" Margin="0,0,8,0"/>
                                <TextBlock Text="Desktop/Laptop" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="12" Height="12" Fill="#FF9C27B0" Margin="0,0,8,0"/>
                                <TextBlock Text="Mobile Device" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="12" Height="12" Fill="#FF757575" Margin="0,0,8,0"/>
                                <TextBlock Text="Unknown Device" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Device Details Panel -->
            <Border x:Name="DetailsPanelBorder" 
                    Grid.Column="1" 
                    Width="400"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Panel Header -->
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Device Details" 
                                      Foreground="{DynamicResource TextBrush}" 
                                      FontSize="20" 
                                      FontWeight="SemiBold"/>
                            <Button Content="?" 
                                   HorizontalAlignment="Right"
                                   Width="30"
                                   Height="30"
                                   Click="CloseDetailsPanel_Click"
                                   Style="{StaticResource BaseButtonStyle}"/>
                        </Grid>

                        <!-- Device Icon and Name -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="DeviceIconText" 
                                          Text="??" 
                                          FontSize="48" 
                                          HorizontalAlignment="Center"
                                          Margin="0,10"/>

                                <TextBlock x:Name="DeviceNameText" 
                                          Text="Device Name" 
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          HorizontalAlignment="Center"
                                          TextWrapping="Wrap"
                                          TextAlignment="Center"/>

                                <TextBlock x:Name="DeviceTypeText" 
                                          Text="Unknown Device" 
                                          Foreground="{DynamicResource AccentBrush}"
                                          FontSize="14"
                                          HorizontalAlignment="Center"
                                          Margin="0,5,0,10"/>
                            </StackPanel>
                        </Border>

                        <!-- Basic Information -->
                        <TextBlock Text="Basic Information" 
                                  Foreground="{DynamicResource TextBrush}" 
                                  FontWeight="SemiBold"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IP Address:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceIPText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MAC Address:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceMACText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Vendor:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceVendorText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hostname:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceHostnameText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Network Information -->
                        <TextBlock Text="Network Information" 
                                  Foreground="{DynamicResource TextBrush}" 
                                  FontWeight="SemiBold"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Parent Device:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceParentText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Connection:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceConnectionText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Network Layer:" 
                                              Foreground="{DynamicResource TextBrush}" 
                                              Opacity="0.7"
                                              FontSize="12"/>
                                    <TextBlock x:Name="DeviceLayerText" 
                                              Grid.Column="1" 
                                              Text="N/A" 
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Open Ports -->
                        <TextBlock Text="Open Ports" 
                                  Foreground="{DynamicResource TextBrush}" 
                                  FontWeight="SemiBold"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="OpenPortsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BackgroundBrush}"
                                                   CornerRadius="4"
                                                   Padding="10,8"
                                                   Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Port}" 
                                                              Foreground="{DynamicResource AccentBrush}"
                                                              FontWeight="Bold"
                                                              FontSize="14"/>
                                                    <TextBlock Grid.Column="1" 
                                                              Text="{Binding Service}" 
                                                              Foreground="{DynamicResource TextBrush}"
                                                              FontSize="12"
                                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Margin="0,10,0,0">
                            <Button x:Name="ScanPortsButton" 
                                   Content="?? Scan Ports" 
                                   Style="{StaticResource SettingsButtonStyle}"
                                   Click="ScanPortsButton_Click"
                                   Height="40"
                                   Margin="0,5"/>

                            <Button x:Name="AccessRouterButton" 
                                   Content="?? Access Router Admin" 
                                   Style="{StaticResource BaseButtonStyle}"
                                   Click="AccessRouterButton_Click"
                                   Height="40"
                                   Margin="0,5"
                                   Visibility="Collapsed"/>

                            <Button x:Name="PingDeviceButton" 
                                   Content="?? Ping Device" 
                                   Style="{StaticResource BaseButtonStyle}"
                                   Click="PingDeviceButton_Click"
                                   Height="40"
                                   Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
