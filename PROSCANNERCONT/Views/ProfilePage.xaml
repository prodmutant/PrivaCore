<Page x:Class="PROSCANNERCONT.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:converters="clr-namespace:PROSCANNERCONT.ValueConverters"
      Background="{DynamicResource BackgroundBrush}"
      Title="Profile">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Profile Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="User Profile" 
                           Foreground="{DynamicResource TextBrush}" 
                           FontSize="24" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="Manage your account settings and preferences"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.7"
                           FontSize="14"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="EditProfileButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Content="Edit Profile"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Click="EditProfile_Click">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Edit"
                                              Width="14"
                                              Height="14"
                                              Margin="0,0,8,0"
                                              Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Edit Profile" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <Button x:Name="SaveChangesButton"
                        Style="{StaticResource BaseButtonStyle}"
                        Content="Save Changes"
                        Background="{DynamicResource AccentBrush}"
                        Padding="16,8"
                        Click="SaveChanges_Click"
                        Visibility="Collapsed">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="FloppyDisk"
                                              Width="14"
                                              Height="14"
                                              Margin="0,0,8,0"
                                              Foreground="White"/>
                                <TextBlock Text="Save Changes" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Profile Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">

                    <!-- Profile Picture Section -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Profile Picture"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <!-- Profile Picture Display -->
                            <Border Width="120"
                                    Height="120"
                                    CornerRadius="60"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="0,0,0,15">
                                <Grid>
                                    <!-- Placeholder Icon -->
                                    <fa:IconBlock Icon="User"
                                                  Foreground="White"
                                                  Width="auto"
                                                  Height="auto"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                                    <!-- Future: Profile Image -->
                                    <Image x:Name="ProfileImageLarge"
                                           Stretch="UniformToFill"
                                           Visibility="Collapsed">
                                        <Image.Clip>
                                            <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60"/>
                                        </Image.Clip>
                                    </Image>
                                </Grid>
                            </Border>

                            <Button x:Name="ChangePhotoButton"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Content="Change Photo"
                                    Padding="12,6"
                                    Click="ChangePhoto_Click">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconBlock Icon="Camera"
                                                          Width="14"
                                                          Height="14"
                                                          Margin="0,0,6,0"
                                                          Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="Change Photo" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Personal Information -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="User"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="Personal Information"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Full Name -->
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Full Name"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <TextBox x:Name="FullNameTextBox"
                                        Grid.Row="1"
                                        Text="Admin User"
                                        Style="{StaticResource TextBoxBase}"
                                        IsReadOnly="True"/>
                            </Grid>

                            <!-- Email -->
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Email Address"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <TextBox x:Name="EmailTextBox"
                                        Grid.Row="1"
                                        Text="admin@company.com"
                                        Style="{StaticResource TextBoxBase}"
                                        IsReadOnly="True"/>
                            </Grid>

                            <!-- Role -->
                            <Grid Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Role"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <ComboBox x:Name="RoleComboBox"
                                         Grid.Row="1"
                                         SelectedIndex="0"
                                         IsEnabled="False"
                                         Style="{StaticResource ComboBoxStyle}">
                                    <ComboBoxItem Content="Security Analyst"/>
                                    <ComboBoxItem Content="Network Administrator"/>
                                    <ComboBoxItem Content="System Administrator"/>
                                    <ComboBoxItem Content="Security Manager"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Security Stats -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="Trophy"
                                              Foreground="{DynamicResource WarningBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="Your Security Stats"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Stats Grid -->
                            <UniformGrid Columns="2" Margin="0,0,0,0">
                                <!-- Scans Performed -->
                                <StackPanel Margin="0,0,10,15">
                                    <TextBlock Text="Total Scans"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"/>
                                    <TextBlock x:Name="TotalScansText"
                                              Text="147"
                                              Foreground="{DynamicResource AccentBrush}"
                                              FontSize="24"
                                              FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Vulnerabilities Found -->
                                <StackPanel Margin="10,0,0,15">
                                    <TextBlock Text="Vulnerabilities Found"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"/>
                                    <TextBlock x:Name="VulnerabilitiesFoundText"
                                              Text="23"
                                              Foreground="{DynamicResource SeverityHighBrush}"
                                              FontSize="24"
                                              FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Hosts Discovered -->
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Hosts Discovered"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"/>
                                    <TextBlock x:Name="HostsDiscoveredText"
                                              Text="89"
                                              Foreground="{DynamicResource SuccessBrush}"
                                              FontSize="24"
                                              FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Achievements -->
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Text="Achievements"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"/>
                                    <TextBlock x:Name="AchievementsText"
                                              Text="8/30"
                                              Foreground="{DynamicResource WarningBrush}"
                                              FontSize="24"
                                              FontWeight="Bold"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">

                    <!-- Account Settings -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="Gear"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="Account Settings"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Department -->
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Department"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <TextBox x:Name="DepartmentTextBox"
                                        Grid.Row="1"
                                        Text="Information Security"
                                        Style="{StaticResource TextBoxBase}"
                                        IsReadOnly="True"/>
                            </Grid>

                            <!-- Employee ID -->
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Employee ID"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <TextBox x:Name="EmployeeIdTextBox"
                                        Grid.Row="1"
                                        Text="EMP-2024-001"
                                        Style="{StaticResource TextBoxBase}"
                                        IsReadOnly="True"/>
                            </Grid>

                            <!-- Last Login -->
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Last Login"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <TextBox x:Name="LastLoginTextBox"
                                        Grid.Row="1"
                                        Text="Today - 14:23"
                                        Style="{StaticResource TextBoxBase}"
                                        IsReadOnly="True"/>
                            </Grid>

                            <!-- Account Status -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Account Status"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                                <Border Grid.Row="1"
                                        Background="{DynamicResource SuccessBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconBlock Icon="CircleCheck"
                                                      Foreground="White"
                                                      Width="14"
                                                      Height="14"
                                                      Margin="0,0,6,0"/>
                                        <TextBlock Text="Active"
                                                  Foreground="White"
                                                  FontSize="12"
                                                  FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Security Preferences -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="Shield"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="Security Preferences"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Two-Factor Authentication -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Two-Factor Authentication"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="14"
                                              FontWeight="SemiBold"/>
                                    <TextBlock Text="Add an extra layer of security to your account"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="TwoFactorCheckBox"
                                         Grid.Column="1"
                                         IsChecked="True"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Email Notifications -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Email Notifications"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="14"
                                              FontWeight="SemiBold"/>
                                    <TextBlock Text="Receive alerts about security events"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="EmailNotificationsCheckBox"
                                         Grid.Column="1"
                                         IsChecked="True"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Auto-lock Session -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Auto-lock Session"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="14"
                                              FontWeight="SemiBold"/>
                                    <TextBlock Text="Automatically lock after 30 minutes of inactivity"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12"
                                              Opacity="0.7"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoLockCheckBox"
                                         Grid.Column="1"
                                         IsChecked="False"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- License Information -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="Key"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="License"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- License Tier Display -->
                            <TextBlock Text="License Tier"
                                      Foreground="{DynamicResource TextBrush}"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>
                            <TextBlock x:Name="LicenseTierText"
                                      Text="License: Free"
                                      Foreground="{DynamicResource AccentBrush}"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Margin="0,0,0,4"/>
                            <TextBlock x:Name="LicenseExpiryText"
                                      Text=""
                                      Foreground="{DynamicResource TextBrush}"
                                      FontSize="11"
                                      Opacity="0.7"
                                      Margin="0,0,0,12"/>

                            <!-- Activate License Button (shown only on Free tier) -->
                            <Button x:Name="ActivateLicenseButton"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Height="36"
                                    Click="ActivateLicense_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Unlock"
                                                  Width="14"
                                                  Height="14"
                                                  Margin="0,0,8,0"
                                                  Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Activate License"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconBlock Icon="Wrench"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Width="16"
                                              Height="16"
                                              Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                          Text="Quick Actions"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Change Password -->
                            <Button x:Name="ChangePasswordButton"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Height="40"
                                    Margin="0,0,0,10"
                                    Click="ChangePassword_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Icon="Key"
                                                  Width="16"
                                                  Height="16"
                                                  Margin="0,0,10,0"
                                                  Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Grid.Column="1"
                                              Text="Change Password"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                                    <fa:IconBlock Grid.Column="2"
                                                  Icon="ChevronRight"
                                                  Width="12"
                                                  Height="12"
                                                  Foreground="{DynamicResource TextBrush}"
                                                  Opacity="0.7"/>
                                </Grid>
                            </Button>

                            <!-- Download Activity Report -->
                            <Button x:Name="DownloadReportButton"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Height="40"
                                    Margin="0,0,0,10"
                                    Click="DownloadReport_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Icon="Download"
                                                  Width="16"
                                                  Height="16"
                                                  Margin="0,0,10,0"
                                                  Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Grid.Column="1"
                                              Text="Download Activity Report"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                                    <fa:IconBlock Grid.Column="2"
                                                  Icon="ChevronRight"
                                                  Width="12"
                                                  Height="12"
                                                  Foreground="{DynamicResource TextBrush}"
                                                  Opacity="0.7"/>
                                </Grid>
                            </Button>

                            <!-- Sign Out -->
                            <Button x:Name="SignOutButton"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Height="40"
                                    Background="{DynamicResource WarningBrush}"
                                    Click="SignOut_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Icon="RightFromBracket"
                                                  Width="16"
                                                  Height="16"
                                                  Margin="0,0,10,0"
                                                  Foreground="White"/>
                                    <TextBlock Grid.Column="1"
                                              Text="Sign Out"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Foreground="White"/>
                                    <fa:IconBlock Grid.Column="2"
                                                  Icon="ChevronRight"
                                                  Width="12"
                                                  Height="12"
                                                  Foreground="White"
                                                  Opacity="0.7"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>