<Page x:Class="PROSCANNERCONT.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32">
            <StackPanel MaxWidth="820" HorizontalAlignment="Left">

                <!-- Page header -->
                <TextBlock Text="My Profile" FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Your account details and security settings."
                           FontSize="13" Foreground="{DynamicResource SubtleTextBrush}"
                           Margin="0,4,0,20"/>

                <!-- Identity card -->
                <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <!-- Initials avatar -->
                        <Border Width="72" Height="72" CornerRadius="36"
                                Background="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                            <TextBlock x:Name="AvatarInitials" Text="?"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource OnAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="DisplayNameText" Text="—"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock x:Name="UsernameSubtitle" Text="@—"
                                       FontSize="13" Foreground="{DynamicResource SubtleTextBrush}"
                                       Margin="0,2,0,8"/>
                            <Border x:Name="RoleBadge" CornerRadius="10" Padding="10,3"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="UserShield" FontSize="11"
                                                  Foreground="{DynamicResource AccentBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="RoleText" Text="—" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Account details card -->
                <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Account details" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Username (read-only) -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Username"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UsernameValue" Text="—"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Display name (editable) -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Display name"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="DisplayNameBox"
                                     Style="{StaticResource InputBoxStyle}" MaxWidth="320"
                                     HorizontalAlignment="Left" Margin="0,0,0,12"/>

                            <!-- Role -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Role"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RoleValue" Text="—"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Account created -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Account created"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CreatedValue" Text="—"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Last sign-in -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Last sign-in"
                                       Foreground="{DynamicResource SubtleTextBrush}" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="LastLoginValue" Text="—"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Button x:Name="SaveNameButton" Content="Save display name"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,18,0,0" MinWidth="150"
                                Click="SaveName_Click"/>
                    </StackPanel>
                </Border>

                <!-- Security card -->
                <Border Style="{StaticResource CardStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Security" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Passwords are stored only as salted PBKDF2 verifiers — never in plain text."
                                   FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"
                                   Margin="0,0,0,16" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Change password" Style="{StaticResource GhostButtonStyle}"
                                    MinWidth="160" Click="ChangePassword_Click"/>
                            <Button Content="Sign out" Style="{StaticResource DangerButtonStyle}"
                                    MinWidth="120" Margin="12,0,0,0" Click="SignOut_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
