<Window x:Class="PROSCANNERCONT.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="PrivaCore — Sign in"
        Width="440" Height="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- draggable title strip + close -->
            <Grid Grid.Row="0" x:Name="TitleBar" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Button x:Name="CloseBtn" Content="✕" Click="Close_Click" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Width="40" Height="40" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource SubtleTextBrush}"
                        FontSize="14" Cursor="Hand"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="40,0,40,36" VerticalAlignment="Center">

                <!-- brand -->
                <fa:IconBlock Icon="Shield" FontSize="40"
                              Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TitleText" Text="Welcome back" FontSize="26" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,16,0,4"/>
                <TextBlock x:Name="SubtitleText" Text="Sign in to your PrivaCore console."
                           FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,22"/>

                <!-- error / info banner -->
                <Border x:Name="ErrorBanner" Visibility="Collapsed" Margin="0,0,0,16"
                        Background="#26FF7B72" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,9">
                    <TextBlock x:Name="ErrorText" Foreground="{DynamicResource CriticalBrush}"
                               FontSize="12.5" TextWrapping="Wrap"/>
                </Border>

                <!-- Username -->
                <TextBlock x:Name="UserLabel" Text="Username" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Style="{DynamicResource InputBoxStyle}" Height="42"
                         FontSize="14" Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock x:Name="PasswordLabel" Text="Password" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Style="{DynamicResource PasswordBoxStyle}" Height="42"
                             FontSize="14" Margin="0,0,0,16"/>

                <!-- Confirm password (setup / change modes) -->
                <StackPanel x:Name="ConfirmPanel" Visibility="Collapsed">
                    <TextBlock Text="Confirm password" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmBox" Style="{DynamicResource PasswordBoxStyle}" Height="42"
                                 FontSize="14" Margin="0,0,0,16"/>
                </StackPanel>

                <Button x:Name="PrimaryButton" Content="Sign in" Click="Primary_Click"
                        Style="{DynamicResource AccentButtonStyle}" Height="44" FontSize="14"
                        Margin="0,8,0,0"/>

                <TextBlock x:Name="HintText" Text="" FontSize="11.5" TextWrapping="Wrap"
                           Foreground="{DynamicResource SubtleTextBrush}" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
