<Page x:Class="PROSCANNERCONT.Views.TrafficAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:local="clr-namespace:PROSCANNERCONT.Views"
      mc:Ignorable="d"
      Background="{DynamicResource BackgroundBrush}">

  <Page.Resources>

    <!-- Converters -->
    <local:ProtocolToColorConverter   x:Key="ProtocolToColorConverter"/>
    <local:ThreatLevelToColorConverter x:Key="ThreatLevelToColorConverter"/>
    <local:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
    <local:BytesToStringConverter     x:Key="BytesToStringConverter"/>

    <!-- ── Toolbar icon button ── -->
    <Style x:Key="ToolBtn" TargetType="Button">
      <Setter Property="Width"           Value="34"/>
      <Setter Property="Height"          Value="34"/>
      <Setter Property="Padding"         Value="0"/>
      <Setter Property="Margin"          Value="1,0"/>
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="{DynamicResource CornerRadiusSmall}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Primary action button ── -->
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="14,0"/>
      <Setter Property="Height"          Value="36"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="FontFamily"      Value="{DynamicResource PrimaryFont}"/>
      <Setter Property="FontSize"        Value="{DynamicResource FontSizeNormal}"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="{DynamicResource CornerRadiusNormal}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Tab item ── -->
    <Style x:Key="WireTab" TargetType="TabItem">
      <Setter Property="Background"  Value="Transparent"/>
      <Setter Property="Foreground"  Value="{DynamicResource SubtleTextBrush}"/>
      <Setter Property="Padding"     Value="14,7"/>
      <Setter Property="FontFamily"  Value="{DynamicResource PrimaryFont}"/>
      <Setter Property="FontSize"    Value="{DynamicResource FontSizeNormal}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="bd" Background="Transparent"
                    BorderThickness="0,0,0,2"
                    BorderBrush="Transparent"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                <Setter TargetName="bd" Property="Background"  Value="{DynamicResource HoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Field label ── -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground"  Value="{DynamicResource SubtleTextBrush}"/>
      <Setter Property="FontSize"    Value="10"/>
      <Setter Property="FontWeight"  Value="Bold"/>
      <Setter Property="FontFamily"  Value="{DynamicResource PrimaryFont}"/>
    </Style>

    <!-- ── Stat card ── -->
    <Style x:Key="StatCard" TargetType="Border">
      <Setter Property="Background"      Value="{DynamicResource SecondaryBackgroundBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="{DynamicResource CornerRadiusNormal}"/>
      <Setter Property="Padding"         Value="12,8"/>
      <Setter Property="Margin"          Value="0,0,8,0"/>
      <Setter Property="MinWidth"        Value="90"/>
    </Style>

    <!-- ── Packet list DataGrid ─────────────────────────────────────────────
         CRITICAL: EnableColumnVirtualization="False" prevents star-column
         collapse when rows are added live.  VirtualizationMode="Standard"
         is also required — "Recycling" has a known WPF layout-recalc bug
         that triggers column width resets.
    ── -->
    <Style x:Key="PacketGrid" TargetType="DataGrid">
      <Setter Property="Background"                  Value="Transparent"/>
      <Setter Property="BorderThickness"             Value="0"/>
      <Setter Property="GridLinesVisibility"         Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush"    Value="{DynamicResource BorderBrush}"/>
      <Setter Property="RowBackground"               Value="Transparent"/>
      <Setter Property="AlternatingRowBackground"    Value="{DynamicResource HoverBrush}"/>
      <Setter Property="HeadersVisibility"           Value="Column"/>
      <Setter Property="CanUserAddRows"              Value="False"/>
      <Setter Property="CanUserDeleteRows"           Value="False"/>
      <Setter Property="AutoGenerateColumns"         Value="False"/>
      <Setter Property="EnableRowVirtualization"     Value="True"/>
      <Setter Property="EnableColumnVirtualization"  Value="False"/>
      <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
      <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Standard"/>
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Visible"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="RowHeight"        Value="26"/>
      <Setter Property="Foreground"       Value="{DynamicResource TextBrush}"/>
      <Setter Property="FontFamily"       Value="{DynamicResource MonoFont}"/>
      <Setter Property="FontSize"         Value="12"/>
      <Setter Property="SelectionMode"    Value="Extended"/>
      <Setter Property="SelectionUnit"    Value="FullRow"/>
      <Setter Property="IsReadOnly"       Value="True"/>
      <Setter Property="CanUserResizeColumns"  Value="True"/>
      <Setter Property="CanUserReorderColumns" Value="False"/>
      <Setter Property="CanUserSortColumns"    Value="True"/>
      <Setter Property="ColumnHeaderStyle">
        <Setter.Value>
          <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource PrimaryFont}"/>
            <Setter Property="FontSize"        Value="11"/>
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="CellStyle">
        <Setter.Value>
          <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

  </Page.Resources>

  <!-- ═══════════════ ROOT ═══════════════════════════════════════════════════ -->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- header -->
      <RowDefinition Height="Auto"/>  <!-- toolbar -->
      <RowDefinition Height="*"/>     <!-- content -->
    </Grid.RowDefinitions>

    <!-- ═══ HEADER ══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{DynamicResource AccentBrush}"
                  Width="36" Height="36"
                  CornerRadius="{DynamicResource CornerRadiusNormal}"
                  Margin="0,0,12,0">
            <fa:IconBlock Icon="ChartLine" Foreground="White" FontSize="16"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Traffic Analysis"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="CaptureStatusText"
                       Text="Ready to capture"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontSize="11" Margin="0,1,0,0"/>
          </StackPanel>
        </StackPanel>

        <!-- Stat cards -->
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="16,0">

          <Border Style="{StaticResource StatCard}">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="TotalPacketsText" Text="0"
                         Foreground="{DynamicResource AccentBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="PACKETS"
                         Foreground="{DynamicResource SubtleTextBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource StatCard}">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="TotalBytesText" Text="0 B"
                         Foreground="{DynamicResource SuccessBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="DATA"
                         Foreground="{DynamicResource SubtleTextBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource StatCard}">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="PacketsPerSecText" Text="0/s"
                         Foreground="{DynamicResource WarningBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="RATE"
                         Foreground="{DynamicResource SubtleTextBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource StatCard}" Margin="0">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="AlertsCountText" Text="0"
                         Foreground="{DynamicResource CriticalBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="ALERTS"
                         Foreground="{DynamicResource SubtleTextBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Start/Stop -->
        <Button Grid.Column="2"
                x:Name="StartStopButton"
                Style="{StaticResource ActionBtn}"
                Click="StartStopCapture_Click"
                Width="148">
          <StackPanel Orientation="Horizontal">
            <fa:IconBlock x:Name="StartStopIcon" Icon="Play"
                          Foreground="White" FontSize="12"
                          VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="StartStopText" Text="Start Capture"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontWeight="SemiBold" Foreground="White"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- ═══ TOOLBAR ═════════════════════════════════════════════════════════ -->
    <Border Grid.Row="1"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,5">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Interface selector -->
        <ComboBox x:Name="InterfaceComboBox"
                  Style="{StaticResource ComboBoxStyle}"
                  Width="240" Height="30"
                  SelectionChanged="InterfaceComboBox_SelectionChanged"
                  ToolTip="Capture interface"/>

        <!-- Icon toolbar -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0">
          <Border Width="1" Background="{DynamicResource BorderBrush}" Opacity="0.5"
                  Margin="4,4" VerticalAlignment="Stretch"/>

          <Button Style="{StaticResource ToolBtn}" Click="ClearCapture_Click"   ToolTip="Clear capture">
            <fa:IconBlock Icon="Trash"      Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
          <Button Style="{StaticResource ToolBtn}" Click="ExportCapture_Click"  ToolTip="Export capture">
            <fa:IconBlock Icon="Download"   Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
          <Button Style="{StaticResource ToolBtn}" Click="ImportCapture_Click"  ToolTip="Import PCAP">
            <fa:IconBlock Icon="Upload"     Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>

          <Border Width="1" Background="{DynamicResource BorderBrush}" Opacity="0.5"
                  Margin="4,4" VerticalAlignment="Stretch"/>

          <Button Style="{StaticResource ToolBtn}" Click="ScrollToTop_Click"    ToolTip="Jump to first">
            <fa:IconBlock Icon="AnglesUp"   Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
          <Button Style="{StaticResource ToolBtn}" Click="ScrollToBottom_Click" ToolTip="Jump to last">
            <fa:IconBlock Icon="AnglesDown" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
        </StackPanel>

        <!-- Display filter -->
        <Grid Grid.Column="2" x:Name="FilterInputRoot" Margin="6,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <Border Background="{DynamicResource BackgroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource CornerRadiusNormal}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <fa:IconBlock Grid.Column="0" Icon="Filter"
                            Foreground="{DynamicResource SubtleTextBrush}"
                            FontSize="10" Margin="8,0,4,0" VerticalAlignment="Center"/>

              <TextBox Grid.Column="1"
                       x:Name="DisplayFilterInput"
                       Background="Transparent"
                       BorderThickness="0"
                       Foreground="{DynamicResource TextBrush}"
                       CaretBrush="{DynamicResource AccentBrush}"
                       VerticalContentAlignment="Center"
                       Padding="4,5"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="12"
                       Height="30"
                       TextChanged="FilterInput_TextChanged"
                       KeyDown="DisplayFilter_KeyDown"
                       LostFocus="FilterInput_LostFocus"/>

              <Button Grid.Column="2"
                      Style="{StaticResource ToolBtn}"
                      Width="28" Height="28"
                      Click="ClearFilter_Click" ToolTip="Clear filter">
                <fa:IconBlock Icon="Xmark" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9"/>
              </Button>
            </Grid>
          </Border>

          <!-- Autocomplete popup -->
          <Popup x:Name="AutocompletePopup"
                 PlacementTarget="{Binding ElementName=FilterInputRoot}"
                 Placement="Bottom"
                 StaysOpen="False"
                 AllowsTransparency="True"
                 PopupAnimation="Fade">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0,0,4,4"
                    MinWidth="200" MaxHeight="180">
              <ListBox x:Name="AutocompleteList"
                       Background="Transparent"
                       BorderThickness="0"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="12"
                       Foreground="{DynamicResource TextBrush}"
                       SelectionChanged="Autocomplete_SelectionChanged"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Cursor"  Value="Hand"/>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </ListBox.ItemContainerStyle>
              </ListBox>
            </Border>
          </Popup>

          <Button Grid.Column="1"
                  Style="{StaticResource ActionBtn}"
                  Click="ApplyFilter_Click"
                  Width="70" Margin="6,0,0,0"
                  VerticalAlignment="Center">
            <TextBlock Text="Apply" FontFamily="{DynamicResource PrimaryFont}"
                       FontWeight="SemiBold" Foreground="White"/>
          </Button>
        </Grid>

        <!-- Right icons: side panels -->
        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Border Width="1" Background="{DynamicResource BorderBrush}" Opacity="0.5"
                  Margin="4,4" VerticalAlignment="Stretch"/>
          <Button Style="{StaticResource ToolBtn}" Click="ToggleStatistics_Click"   ToolTip="Statistics">
            <fa:IconBlock Icon="ChartBar"  Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
          <Button Style="{StaticResource ToolBtn}" Click="ToggleConversations_Click" ToolTip="Conversations">
            <fa:IconBlock Icon="RightLeft" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
          <Button Style="{StaticResource ToolBtn}" Click="ToggleAlerts_Click"        ToolTip="Alerts">
            <fa:IconBlock Icon="Bell"      Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition x:Name="SidePanelColumn" Width="0"/>
      </Grid.ColumnDefinitions>

      <!-- Three-pane Wireshark layout -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"   MinHeight="140"/>
          <RowDefinition Height="5"/>
          <RowDefinition Height="240" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- ── PACKET LIST ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
          <DataGrid x:Name="PacketGrid"
                    Style="{StaticResource PacketGrid}"
                    SelectionChanged="PacketGrid_SelectionChanged"
                    MouseDoubleClick="PacketGrid_MouseDoubleClick">

            <!-- Row coloring: protocol tint as base, hover/select override -->
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background"
                        Value="{Binding Protocol, Converter={StaticResource ProtocolToColorConverter}}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
              <DataGridTextColumn Header="No."
                                  Binding="{Binding PacketNumber}"
                                  Width="55" MinWidth="45"
                                  SortMemberPath="PacketNumber"/>
              <DataGridTextColumn Header="Time"
                                  Binding="{Binding FormattedTimestamp}"
                                  Width="105" MinWidth="80"/>
              <DataGridTextColumn Header="Source"
                                  Binding="{Binding SourceEndpoint}"
                                  Width="155" MinWidth="120"/>
              <DataGridTextColumn Header="Destination"
                                  Binding="{Binding DestinationEndpoint}"
                                  Width="155" MinWidth="120"/>
              <DataGridTextColumn Header="Protocol"
                                  Binding="{Binding Protocol}"
                                  Width="68" MinWidth="55"/>
              <DataGridTextColumn Header="Len"
                                  Binding="{Binding Length}"
                                  Width="58" MinWidth="48"/>
              <!-- Info column: MinWidth="200" prevents star-width collapse -->
              <DataGridTextColumn Header="Info"
                                  Binding="{Binding Info}"
                                  Width="*" MinWidth="200"/>
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <!-- ── RESIZE HANDLE ── -->
        <GridSplitter Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"
                      Cursor="SizeNS"/>

        <!-- ── BOTTOM PANEL ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryBackgroundBrush}">
          <TabControl x:Name="DetailTabs"
                      Background="Transparent"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="0,1,0,0">
            <TabControl.Resources>
              <Style TargetType="TabItem" BasedOn="{StaticResource WireTab}"/>
            </TabControl.Resources>

            <!-- ── Packet Details ── -->
            <TabItem Header="Packet Details">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="5"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Protocol tree -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,0">
                  <TreeView x:Name="ProtocolTree"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource TextBrush}"
                            FontFamily="{DynamicResource MonoFont}"
                            FontSize="11"
                            Padding="6"/>
                </Border>

                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              Cursor="SizeWE"/>

                <!-- Hex dump -->
                <Border Grid.Column="2"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,0">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="HexDumpText"
                               Background="Transparent"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="10"
                               Padding="8"
                               TextWrapping="NoWrap"
                               Text="Select a packet to view hex dump"/>
                  </ScrollViewer>
                </Border>
              </Grid>
            </TabItem>

            <!-- ── Filters ── -->
            <TabItem Header="Filters">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">
                  <TextBlock Text="Protocols"
                             Foreground="{DynamicResource SubtleTextBrush}"
                             FontFamily="{DynamicResource PrimaryFont}"
                             FontSize="10" FontWeight="Bold"
                             Margin="0,0,0,8"/>
                  <WrapPanel Margin="0,0,0,14">
                    <CheckBox x:Name="FilterTCP"   Content="TCP"   Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterUDP"   Content="UDP"   Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterICMP"  Content="ICMP"  Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterHTTP"  Content="HTTP"  Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterHTTPS" Content="HTTPS" Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterDNS"   Content="DNS"   Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="FilterSSH"   Content="SSH"   Style="{StaticResource CheckBoxStyle}" Margin="0,0,14,4" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                  </WrapPanel>

                  <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="IP ADDRESS" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                      <TextBox x:Name="FilterIP"
                               Style="{StaticResource TextBoxBase}"
                               Height="32" Padding="8,4"
                               TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="PORT" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                      <TextBox x:Name="FilterPort"
                               Style="{StaticResource TextBoxBase}"
                               Height="32" Padding="8,4"
                               TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <Button Grid.Column="3"
                            Style="{StaticResource ActionBtn}"
                            Click="ResetFilters_Click"
                            Margin="10,0,0,0"
                            VerticalAlignment="Bottom">
                      <TextBlock Text="Reset" FontFamily="{DynamicResource PrimaryFont}"
                                 FontWeight="SemiBold" Foreground="White"/>
                    </Button>
                  </Grid>

                  <CheckBox x:Name="FilterThreatsOnly"
                            Content="Show only packets with threats"
                            Style="{StaticResource CheckBoxStyle}"
                            Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <!-- ── Stream ── -->
            <TabItem Header="Stream">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
                  <Button Style="{StaticResource ActionBtn}" Click="FollowTcpStream_Click" Margin="0,0,8,0">
                    <TextBlock Text="Follow TCP Stream" FontFamily="{DynamicResource PrimaryFont}"
                               FontWeight="SemiBold" Foreground="White"/>
                  </Button>
                  <Button Style="{StaticResource ActionBtn}" Click="FollowUdpStream_Click"
                          Background="{DynamicResource SubtleTextBrush}">
                    <TextBlock Text="Follow UDP Stream" FontFamily="{DynamicResource PrimaryFont}"
                               FontWeight="SemiBold" Foreground="White"/>
                  </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="StreamContentText"
                               Background="Transparent"
                               Foreground="{DynamicResource TextBrush}"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="11"
                               Padding="10"
                               TextWrapping="Wrap"
                               Text="Select a packet and click Follow TCP/UDP Stream."/>
                  </ScrollViewer>
                </Border>
              </Grid>
            </TabItem>

          </TabControl>
        </Border>
      </Grid>

      <!-- ── SIDE PANEL ── -->
      <Border Grid.Column="1"
              x:Name="SidePanel"
              Background="{DynamicResource SecondaryBackgroundBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1,0,0,0"
              Visibility="Collapsed">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0"
                  Background="{DynamicResource HoverBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="12,9">
            <Grid>
              <TextBlock x:Name="SidePanelTitle"
                         Text="Statistics"
                         Foreground="{DynamicResource TextBrush}"
                         FontFamily="{DynamicResource PrimaryFont}"
                         FontWeight="SemiBold" FontSize="13"/>
              <Button HorizontalAlignment="Right"
                      Style="{StaticResource ToolBtn}"
                      Width="26" Height="26"
                      Click="CloseSidePanel_Click">
                <fa:IconBlock Icon="Xmark" Foreground="{DynamicResource SubtleTextBrush}" FontSize="10"/>
              </Button>
            </Grid>
          </Border>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="SidePanelContent"/>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>
