<Page x:Class="PROSCANNERCONT.Views.HoneypotDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:converters="clr-namespace:PROSCANNERCONT.Converters"
      xmlns:v="clr-namespace:PROSCANNERCONT.Views"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="Honeypot Dashboard"
      Background="{DynamicResource SecondaryBackgroundBrush}">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <TabControl Background="{DynamicResource BackgroundBrush}" BorderThickness="0" Margin="8">
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <DockPanel Background="{DynamicResource BackgroundBrush}">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TabPanel IsItemsHost="True" Margin="6,6,6,0" Background="Transparent"/>
                    </Border>
                    <ContentPresenter ContentSource="SelectedContent"/>
                </DockPanel>
            </ControlTemplate>
        </TabControl.Template>
        <TabItem Style="{StaticResource TabItemStyle}">
            <TabItem.Header><TextBlock Text="Live Capture"/></TabItem.Header>
            <v:HoneypotCaptureView/>
        </TabItem>
        <TabItem Style="{StaticResource TabItemStyle}">
            <TabItem.Header><TextBlock Text="Decoy VMs"/></TabItem.Header>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== HEADER ==================== -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title Section -->
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <Border Background="{DynamicResource AccentBrush}" Width="36" Height="36"
                            CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center">
                        <fa:IconBlock Icon="Eye" Foreground="White" FontSize="18"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Honeypot Command Center"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="LastUpdateText"
                           Text="Last updated: Never"
                           FontSize="13"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Opacity="0.7"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">

                <Button x:Name="RefreshButton"
                        Click="RefreshDashboard_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Padding="15,10"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Refresh VM states">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ArrowsRotate" Foreground="White" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Refresh" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Click="StartAllHoneypots_Click"
                        Background="{DynamicResource SuccessBrush}"
                        Foreground="White"
                        Padding="15,10"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Start all stopped honeypots">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Play" Foreground="White" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Start All" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Click="StopAllHoneypots_Click"
                        Background="{DynamicResource CriticalBrush}"
                        Foreground="White"
                        Padding="15,10"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Stop all running honeypots">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Stop" Foreground="White" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Stop All" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button Click="AddHoneypot_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Padding="15,10"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        ToolTip="Create a new honeypot">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Plus" Foreground="White" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Add Honeypot" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== STATISTICS PANEL ==================== -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Honeypots -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource HoverBrush}" 
                    Padding="20" 
                    Margin="0,0,10,0"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="0,3,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconBlock Icon="Database" Foreground="{DynamicResource AccentBrush}"
                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Total Honeypots"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="TotalVMsText"
                               Text="0"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="TotalActiveText"
                               Text="0 active"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Running VMs -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource HoverBrush}" 
                    Padding="20" 
                    Margin="0,0,10,0"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource SuccessBrush}"
                    BorderThickness="0,3,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconBlock Icon="CirclePlay" Foreground="{DynamicResource SuccessBrush}"
                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Running"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="RunningVMsText"
                               Text="0"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="RunningPercentText"
                               Text="0%"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- SSH Connected -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource HoverBrush}" 
                    Padding="20" 
                    Margin="0,0,10,0"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource AccentLightBrush}"
                    BorderThickness="0,3,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconBlock Icon="Link" Foreground="{DynamicResource AccentLightBrush}"
                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SSH Connected"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ConnectedAgentsText"
                               Text="0"
                               Foreground="{DynamicResource AccentLightBrush}"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="AgentHealthText"
                               Text="No SSH"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Attack Attempts -->
            <Border Grid.Column="3" 
                    Background="{DynamicResource HoverBrush}" 
                    Padding="20" 
                    Margin="0,0,10,0"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource CriticalBrush}"
                    BorderThickness="0,3,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconBlock Icon="TriangleExclamation" Foreground="{DynamicResource CriticalBrush}"
                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Attack Attempts"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="AttackAttemptsText"
                               Text="0"
                               Foreground="{DynamicResource CriticalBrush}"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="AttackRateText"
                               Text="0/hour"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Active Alerts -->
            <Border Grid.Column="4" 
                    Background="{DynamicResource HoverBrush}" 
                    Padding="20"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource WarningBrush}"
                    BorderThickness="0,3,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconBlock Icon="Bell" Foreground="{DynamicResource WarningBrush}"
                                      FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Active Alerts"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ActiveAlertsText"
                               Text="0"
                               Foreground="{DynamicResource WarningBrush}"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <Button x:Name="ViewAlertsButton"
                            Content="View All"
                            Click="ViewAlerts_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0"
                            Cursor="Hand"
                            FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ==================== FILTER/SEARCH BAR ==================== -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Border Grid.Column="0"
                    Background="{DynamicResource HoverBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <fa:IconBlock Grid.Column="0"
                               Icon="MagnifyingGlass"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             VerticalAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"
                             Text="Search honeypots..."/>

                    <Button Grid.Column="2"
                            Click="ClearSearch_Click"
                            Background="Transparent"
                            Foreground="{DynamicResource SubtleTextBrush}"
                            BorderThickness="0"
                            Padding="8,0"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            x:Name="ClearSearchButton">
                        <fa:IconBlock Icon="Xmark" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="FilterAllButton"
                        Content="All"
                        Tag="All"
                        Click="FilterButton_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Padding="15,8"
                        Margin="0,0,5,0"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button x:Name="FilterRunningButton"
                        Tag="Running"
                        Click="FilterButton_Click"
                        Background="{DynamicResource BorderBrush}"
                        Foreground="White"
                        Padding="15,8"
                        Margin="0,0,5,0"
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="CirclePlay" FontSize="12" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,5,0"/>
                        <TextBlock Text="Running" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button x:Name="FilterStoppedButton"
                        Tag="Stopped"
                        Click="FilterButton_Click"
                        Background="{DynamicResource BorderBrush}"
                        Foreground="White"
                        Padding="15,8"
                        Margin="0,0,5,0"
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="CircleStop" FontSize="12" Foreground="{DynamicResource CriticalBrush}" Margin="0,0,5,0"/>
                        <TextBlock Text="Stopped" Foreground="White"/>
                    </StackPanel>
                </Button>

                <Button x:Name="FilterAgentButton"
                        Tag="Agent"
                        Click="FilterButton_Click"
                        Background="{DynamicResource BorderBrush}"
                        Foreground="White"
                        Padding="15,8"
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Terminal" FontSize="12" Foreground="{DynamicResource AccentLightBrush}" Margin="0,0,5,0"/>
                        <TextBlock Text="SSH Configured" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== VM LIST ==================== -->
        <Border Grid.Row="3" 
                Background="{DynamicResource HoverBrush}" 
                CornerRadius="8"
                Padding="0">

            <Grid>
                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <fa:IconBlock Icon="Eye"
                               FontSize="64"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Opacity="0.3"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="No Honeypots Yet"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Deploy your first honeypot to start monitoring threats"
                               FontSize="14"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                    <Button Click="AddHoneypot_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            Padding="25,12"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Plus" FontSize="15" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="Deploy First Honeypot" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- VM List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="VMListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BorderBrush}" 
                                        Margin="15"
                                        Padding="20"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- TOP ROW -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- VM Icon + Name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="48" Height="48"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="8"
                                                        Margin="0,0,15,0">
                                                    <fa:IconBlock Icon="Server" Foreground="White"
                                                                  FontSize="22"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource SuccessBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,15,0"/>
                                                        <TextBlock Text="{Binding AgentStatusDisplay}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Stats -->
                                            <StackPanel Grid.Column="1" 
                                                        Orientation="Horizontal" 
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Border Background="{DynamicResource HoverBrush}" 
                                                        Padding="12,8" 
                                                        CornerRadius="6"
                                                        Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Attacks"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TotalConnectionAttempts}"
                                                                   Foreground="#F48771"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="{DynamicResource HoverBrush}" 
                                                        Padding="12,8" 
                                                        CornerRadius="6"
                                                        Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Failed Logins"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding FailedLoginAttempts}"
                                                                   Foreground="#DCDCAA"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="{DynamicResource HoverBrush}" 
                                                        Padding="12,8" 
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock Text="Alerts"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding AlertCount}"
                                                                   Foreground="#C586C0"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Action Buttons -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Tag="{Binding}"
                                                        Click="ViewHoneypot_Click"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Width="36" Height="36"
                                                        Margin="5,0"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="View VM Console">
                                                    <fa:IconBlock Icon="Desktop" Foreground="White" FontSize="14"/>
                                                </Button>

                                                <Button Tag="{Binding}"
                                                        Click="TerminalHoneypot_Click"
                                                        Background="#C586C0"
                                                        Width="36" Height="36"
                                                        Margin="5,0"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Open Terminal">
                                                    <fa:IconBlock Icon="Terminal" Foreground="White" FontSize="14"/>
                                                </Button>

                                                <Button Tag="{Binding}"
                                                        Click="StartStopHoneypot_Click"
                                                        Background="#4EC9B0"
                                                        Width="36" Height="36"
                                                        Margin="5,0"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Start/Stop VM">
                                                    <fa:IconBlock Icon="PowerOff" Foreground="White" FontSize="14"/>
                                                </Button>

                                                <Button Tag="{Binding}"
                                                        Click="SettingsHoneypot_Click"
                                                        Background="#6C6C6C"
                                                        Width="36" Height="36"
                                                        Margin="5,0"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Settings">
                                                    <fa:IconBlock Icon="Gear" Foreground="White" FontSize="14"/>
                                                </Button>

                                                <Button Tag="{Binding}"
                                                        Click="DeleteHoneypot_Click"
                                                        Background="#F44747"
                                                        Width="36" Height="36"
                                                        Margin="5,0"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Delete">
                                                    <fa:IconBlock Icon="Trash" Foreground="White" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- MIDDLE ROW: VM SPECS -->
                                        <StackPanel Grid.Row="1" 
                                                    Orientation="Horizontal" 
                                                    Margin="0,15,0,0">
                                            <Border Background="{DynamicResource HoverBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6"
                                                    Margin="0,0,8,0">
                                                <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                                    <Run Text="OS: "/>
                                                    <Run Text="{Binding OSType}" FontWeight="Bold"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="{DynamicResource HoverBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6"
                                                    Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconBlock Icon="Memory" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                                        <Run Text="{Binding MemoryMB}" FontWeight="Bold"/>
                                                        <Run Text=" MB"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{DynamicResource HoverBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6"
                                                    Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconBlock Icon="Microchip" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                                        <Run Text="{Binding CPUCores}" FontWeight="Bold"/>
                                                        <Run Text=" cores"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{DynamicResource HoverBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6"
                                                    Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconBlock Icon="HardDrive" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                                        <Run Text="{Binding StorageSizeGB}" FontWeight="Bold"/>
                                                        <Run Text=" GB"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{DynamicResource HoverBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconBlock Icon="NetworkWired" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="12">
                                                        <Run Text="{Binding NetworkAdapter}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- BOTTOM ROW: SSH INFO -->
                                        <Border Grid.Row="2"
                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                CornerRadius="6"
                                                Padding="12"
                                                Margin="0,12,0,0"
                                                Visibility="{Binding HasSSHConfigured, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="SSH Connection"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding SSHConnectionString}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Last Connected"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding AgentLastConnectedText}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Open Ports"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding OpenPorts}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="3"
                                                        Tag="{Binding}"
                                                        Click="AgentDashboard_Click"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="White"
                                                        Padding="12,6"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        FontSize="12"
                                                        VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconBlock Icon="Terminal" FontSize="11" Foreground="White" Margin="0,0,5,0"/>
                                                        <TextBlock Text="SSH Dashboard" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
        </TabItem>
    </TabControl>
</Page>
