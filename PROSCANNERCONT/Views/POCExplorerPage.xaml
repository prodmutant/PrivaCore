<Page x:Class="PROSCANNERCONT.Views.POCExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Background="{DynamicResource BackgroundBrush}"
      Title="POC Explorer"
      Unloaded="Page_Unloaded">

    <Page.Resources>
        <!-- CVE list item style -->
        <Style x:Key="CveItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section card -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <!-- Tab button -->
        <Style x:Key="TabBtnStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="PocTabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="tb" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Monospace TextBox for scripts -->
        <Style x:Key="ScriptBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SuccessBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- LEFT PANEL — CVE list                                          -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1"
                    Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="{DynamicResource SeverityCriticalBrush}" Width="26" Height="26" CornerRadius="7" Margin="0,0,9,0">
                            <fa:IconBlock Icon="SkullCrossbones" Foreground="White" Width="12" Height="12"/>
                        </Border>
                        <TextBlock Text="POC Explorer" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Select a CVE to explore exploits, generate Metasploit scripts, and manage your listener."
                               FontSize="10" Opacity="0.5" Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Search + filter -->
            <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconBlock Icon="MagnifyingGlass" Width="11" Height="11"
                                         Foreground="{DynamicResource TextBrush}" Opacity="0.4" Margin="8,0,4,0"/>
                            <TextBox x:Name="CveSearchBox" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextBrush}" FontSize="12"
                                     Padding="0,6" CaretBrush="{DynamicResource TextBrush}"
                                     TextChanged="CveSearch_TextChanged"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource BaseButtonStyle}"
                            Height="28" Padding="8,0" Click="RefreshCveList_Click" ToolTip="Reload from scan results">
                        <fa:IconBlock Icon="ArrowsRotate" Width="11" Height="11"
                                      Foreground="{DynamicResource TextBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- CVE list -->
            <ListBox x:Name="CveListBox" Grid.Row="2"
                     Background="Transparent" BorderThickness="0,0,1,0"
                     BorderBrush="{DynamicResource BorderBrush}"
                     Padding="6,6,6,6"
                     ItemContainerStyle="{StaticResource CveItemStyle}"
                     SelectionChanged="CveListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CveId}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1" CornerRadius="3" Padding="5,1"
                                        Background="{Binding SeverityBrush}">
                                    <TextBlock Text="{Binding Severity}" FontSize="9" Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{Binding TargetService}" FontSize="10"
                                       Opacity="0.5" Foreground="{DynamicResource TextBrush}"
                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"/>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- RIGHT PANEL — tabs                                             -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar + target config -->
            <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tabs -->
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabExploits" Style="{StaticResource TabBtnStyle}"
                                     IsChecked="True" Checked="Tab_Checked" Tag="0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Bomb" Width="11" Height="11" Margin="0,0,5,0"/>
                                <TextBlock Text="Exploits"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="TabMsf" Style="{StaticResource TabBtnStyle}"
                                     Checked="Tab_Checked" Tag="1" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Terminal" Width="11" Height="11" Margin="0,0,5,0"/>
                                <TextBlock Text="Metasploit"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="TabDelivery" Style="{StaticResource TabBtnStyle}"
                                     Checked="Tab_Checked" Tag="2" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="PaperPlane" Width="11" Height="11" Margin="0,0,5,0"/>
                                <TextBlock Text="Delivery"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="TabListener" Style="{StaticResource TabBtnStyle}"
                                     Checked="Tab_Checked" Tag="3">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Satellite" Width="11" Height="11" Margin="0,0,5,0"/>
                                <TextBlock Text="Listener"/>
                                <Border x:Name="ListenerDot" Width="7" Height="7" CornerRadius="4"
                                        Background="#888" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Target config row -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="LHOST:" FontSize="10" Opacity="0.5"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="LhostBox" Width="120" Height="26"
                                 Background="{DynamicResource BackgroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 Foreground="{DynamicResource TextBrush}" FontSize="12"
                                 Padding="6,4" CaretBrush="{DynamicResource TextBrush}"
                                 Text="192.168.1.1" VerticalContentAlignment="Center"/>
                        <TextBlock Text="LPORT:" FontSize="10" Opacity="0.5"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="10,0,4,0"/>
                        <TextBox x:Name="LportBox" Width="55" Height="26"
                                 Background="{DynamicResource BackgroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 Foreground="{DynamicResource TextBrush}" FontSize="12"
                                 Padding="6,4" CaretBrush="{DynamicResource TextBrush}"
                                 Text="4444" VerticalContentAlignment="Center"/>
                        <TextBlock Text="OS:" FontSize="10" Opacity="0.5"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="10,0,4,0"/>
                        <ComboBox x:Name="TargetOsBox" Width="90" Height="26"
                                  Style="{StaticResource ComboBoxStyle}"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="TargetOs_Changed">
                            <ComboBoxItem Content="Windows" IsSelected="True"/>
                            <ComboBoxItem Content="Linux"/>
                            <ComboBoxItem Content="macOS"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── TAB CONTENT ── -->
            <Grid Grid.Row="1">

                <!-- ===================================================== -->
                <!-- TAB 0: EXPLOITS                                         -->
                <!-- ===================================================== -->
                <Grid x:Name="ExploitsTab" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- CVE info banner -->
                    <Border x:Name="CveBanner" Grid.Row="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="BannerCveId" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                                    <Border x:Name="BannerSeverityBadge" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="BannerSeverity" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock x:Name="BannerCvss" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="BannerDesc" FontSize="11" Opacity="0.6"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock x:Name="BannerService" FontSize="10" Opacity="0.45"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}"
                                    Height="32" Padding="14,0"
                                    Click="FetchExploits_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="MagnifyingGlass" Width="11" Height="11" Margin="0,0,6,0"/>
                                    <TextBlock Text="Search Exploit-DB"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Exploit results -->
                    <Grid Grid.Row="1">
                        <!-- Empty / placeholder -->
                        <StackPanel x:Name="ExploitsEmptyPanel"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <fa:IconBlock Icon="SkullCrossbones" Width="48" Height="48"
                                         Foreground="{DynamicResource TextBrush}" Opacity="0.08"
                                         HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a CVE from the list, then click Search Exploit-DB."
                                       FontSize="13" Opacity="0.35" Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Loading -->
                        <StackPanel x:Name="ExploitsLoadingPanel" Visibility="Collapsed"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <fa:IconBlock Icon="CircleNotch" Width="32" Height="32"
                                         Foreground="{DynamicResource AccentBrush}"
                                         RenderTransformOrigin="0.5,0.5">
                                <fa:IconBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinRotation"/>
                                </fa:IconBlock.RenderTransform>
                                <fa:IconBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SpinRotation"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360"
                                                                 Duration="0:0:1"
                                                                 RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </fa:IconBlock.Triggers>
                            </fa:IconBlock>
                            <TextBlock Text="Querying Exploit-DB…" FontSize="12" Opacity="0.5"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Results list -->
                        <ScrollViewer x:Name="ExploitsScrollViewer" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" Padding="16">
                            <StackPanel x:Name="ExploitsPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ===================================================== -->
                <!-- TAB 1: METASPLOIT                                       -->
                <!-- ===================================================== -->
                <Grid x:Name="MsfTab" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Module info bar -->
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="MsfModulePath" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontFamily="Consolas, Courier New"
                                               Text="No module — select a CVE from the list"/>
                                    <Border x:Name="MsfRankBadge" CornerRadius="3" Padding="6,2" Margin="10,0,0,0"
                                            Background="{DynamicResource HoverBrush}" Visibility="Collapsed">
                                        <TextBlock x:Name="MsfRankText" FontSize="9" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="MsfModuleName" FontSize="11" Opacity="0.5"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource BaseButtonStyle}"
                                    Height="30" Padding="10,0" Click="LaunchMsfconsole_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Terminal" Width="11" Height="11" Margin="0,0,5,0"/>
                                    <TextBlock Text="Open in msfconsole"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Script -->
                    <Grid Grid.Row="1" Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="140"/>
                        </Grid.RowDefinitions>

                        <!-- Exploit script -->
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="12,8" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <TextBlock Text="Exploit Script" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Style="{StaticResource BaseButtonStyle}"
                                                Height="24" Padding="8,0" Click="CopyMsfScript_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconBlock Icon="Copy" Width="10" Height="10" Margin="0,0,4,0"/>
                                                <TextBlock Text="Copy" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="MsfScriptBox" Grid.Row="1"
                                         Style="{StaticResource ScriptBoxStyle}"
                                         BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <!-- Handler script -->
                        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="12,8" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <TextBlock Text="Handler (run separately or in background job)"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Style="{StaticResource BaseButtonStyle}"
                                                Height="24" Padding="8,0" Click="CopyHandler_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconBlock Icon="Copy" Width="10" Height="10" Margin="0,0,4,0"/>
                                                <TextBlock Text="Copy" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="MsfHandlerBox" Grid.Row="1"
                                         Style="{StaticResource ScriptBoxStyle}"
                                         BorderThickness="0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Extra options -->
                    <Border Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                        <StackPanel x:Name="MsfOptionsPanel" Orientation="Horizontal"/>
                    </Border>
                </Grid>

                <!-- ===================================================== -->
                <!-- TAB 2: DELIVERY                                         -->
                <!-- ===================================================== -->
                <ScrollViewer x:Name="DeliveryTab" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel x:Name="DeliveryPanel"/>
                </ScrollViewer>

                <!-- ===================================================== -->
                <!-- TAB 3: LISTENER                                         -->
                <!-- ===================================================== -->
                <Grid x:Name="ListenerTab" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Listener controls -->
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="ListenerStatusDot" Width="10" Height="10" CornerRadius="5"
                                        Background="#555" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ListenerStatusText" Text="Stopped"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Port:" FontSize="12" Opacity="0.6"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="ListenerPortBox" Width="60" Height="30"
                                         Background="{DynamicResource BackgroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         Foreground="{DynamicResource TextBrush}" FontSize="12"
                                         Padding="6,0" VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource TextBrush}" Text="4444"/>
                                <Button x:Name="ListenerToggleBtn" Margin="8,0,0,0"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Height="30" Padding="14,0" Click="ListenerToggle_Click">
                                    <TextBlock x:Name="ListenerToggleText" Text="Start Listener"/>
                                </Button>
                                <Button Margin="6,0,0,0" Style="{StaticResource BaseButtonStyle}"
                                        Height="30" Padding="10,0" Click="ListenerClear_Click">
                                    <fa:IconBlock Icon="TrashCan" Width="12" Height="12"
                                                  Foreground="{DynamicResource TextBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Active sessions -->
                    <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="10,6" Visibility="{Binding SessionsPanelVisibility}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="SessionsPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Terminal output -->
                    <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" Margin="0">
                        <ScrollViewer x:Name="TerminalScroller" VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="True">
                            <TextBox x:Name="TerminalOutput"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource SuccessBrush}"
                                     FontFamily="Consolas, Courier New" FontSize="12"
                                     Padding="14,12" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     CaretBrush="{DynamicResource SuccessBrush}"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Command input -->
                    <Border Grid.Row="3" Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid Margin="14,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="$ " FontFamily="Consolas, Courier New" FontSize="13"
                                       Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CommandInputBox" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource SuccessBrush}" CaretBrush="{DynamicResource SuccessBrush}"
                                     FontFamily="Consolas, Courier New" FontSize="13"
                                     VerticalAlignment="Center" Padding="0"
                                     KeyDown="CommandInput_KeyDown"/>
                            <Button Grid.Column="2" Content="Send" Margin="8,0,0,0"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Height="28" Padding="12,0" Click="SendCommand_Click"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
