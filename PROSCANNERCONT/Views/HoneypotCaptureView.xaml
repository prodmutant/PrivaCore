<UserControl x:Class="PROSCANNERCONT.Views.HoneypotCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             Background="{DynamicResource SecondaryBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── control bar ── -->
        <Border Grid.Row="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
            <StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <fa:IconBlock Icon="Bug" Foreground="{DynamicResource AccentBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Decoy service" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ServiceKindBox" Width="130" Height="34" Style="{DynamicResource ComboBoxStyle}" Margin="0,0,10,0"/>
                <TextBlock Text="Port" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="PortBox" Width="80" Height="34" Text="2323" Style="{DynamicResource InputBoxStyle}" Margin="0,0,10,0"/>
                <Button Content="Start decoy" Click="StartDecoy_Click" Style="{DynamicResource AccentButtonStyle}" Height="34" Padding="14,0" Margin="0,0,18,0"/>
                <CheckBox x:Name="FeedSiemBox" Content="Feed hits to SIEM" Style="{DynamicResource CheckBoxStyle}"
                          Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                          Checked="FeedSiem_Changed" Unchecked="FeedSiem_Changed"/>
                <Button Content="Clear hits" Click="ClearHits_Click" Style="{DynamicResource GhostButtonStyle}" Height="34" Padding="12,0" Margin="18,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                <TextBlock Text="Content" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Grid Width="600" Margin="0,0,10,0">
                    <TextBox x:Name="DecoyContentBox" Height="34" Style="{DynamicResource InputBoxStyle}"/>
                    <TextBlock IsHitTestVisible="False" Foreground="{DynamicResource DisabledTextBrush}" Margin="12,0,0,0"
                               VerticalAlignment="Center" FontSize="12" Text="e.g. &lt;html&gt;…&lt;/html&gt; for HTTP, or a login banner">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=DecoyContentBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <TextBlock Text="HTTP → HTML page to serve   ·   Telnet/SSH/FTP → banner   (optional)"
                           Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── stat tiles ── -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="18" Margin="0,0,10,0" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,3,0,0">
                <StackPanel>
                    <TextBlock Text="ACTIVE DECOYS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/>
                    <TextBlock x:Name="ActiveDecoysText" Text="0" Foreground="{DynamicResource TextBrush}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="18" Margin="0,0,10,0" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="0,3,0,0">
                <StackPanel>
                    <TextBlock Text="TOTAL HITS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/>
                    <TextBlock x:Name="TotalHitsText" Text="0" Foreground="{DynamicResource WarningBrush}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="18" Margin="0,0,10,0" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="0,3,0,0">
                <StackPanel>
                    <TextBlock Text="CREDENTIALS CAPTURED" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/>
                    <TextBlock x:Name="CredsText" Text="0" Foreground="{DynamicResource CriticalBrush}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="18" BorderBrush="{DynamicResource AccentLightBrush}" BorderThickness="0,3,0,0">
                <StackPanel>
                    <TextBlock Text="UNIQUE ATTACKERS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/>
                    <TextBlock x:Name="UniqueText" Text="0" Foreground="{DynamicResource AccentLightBrush}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── main area ── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- left: running decoys + top attackers -->
            <Grid Grid.Column="0" Margin="0,0,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="RUNNING DECOYS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="DecoysList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="13">
                                                    <Run Text="{Binding KindName, Mode=OneWay}"/><Run Text="  :"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11">
                                                    <Run Text="{Binding Hits, Mode=OneWay}"/><Run Text=" hits"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Endpoints, Mode=OneWay}" Foreground="{DynamicResource AccentLightBrush}"
                                                           FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Stop" Tag="{Binding}" Click="StopDecoy_Click"
                                                    Style="{DynamicResource GhostButtonStyle}" Height="28" Padding="10,0"
                                                    Foreground="{DynamicResource CriticalBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoDecoysText" Text="No decoys running — start one above." Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="TOP ATTACKERS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="TopAttackersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Ip}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontFamily="Consolas"/>
                                        <Border Grid.Column="1" Background="{DynamicResource CriticalBrush}" CornerRadius="9" Padding="8,1">
                                            <TextBlock Text="{Binding Count}" Foreground="{DynamicResource OnAccentBrush}" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="TOP USERNAMES TRIED" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,14,0,8"/>
                        <ItemsControl x:Name="TopCredsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1" Background="{DynamicResource WarningBrush}" CornerRadius="9" Padding="8,1">
                                            <TextBlock Text="{Binding Count}" Foreground="{DynamicResource OnAccentBrush}" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- right: live hits -->
            <Border Grid.Column="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="LIVE CAPTURES" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="16,14,0,8"/>
                    <DataGrid x:Name="HitsGrid" Grid.Row="1" Style="{DynamicResource DataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" Margin="8,0,8,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="Auto"/>
                            <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="Auto"/>
                            <DataGridTextColumn Header="Tags" Binding="{Binding TagsText}" Width="Auto"/>
                            <DataGridTextColumn Header="Source IP" Binding="{Binding SourceIp}" Width="Auto"/>
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="2*"/>
                            <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
