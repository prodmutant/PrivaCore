<Window x:Class="PROSCANNERCONT.Views.VMTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VM Terminal" 
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#0D7D56"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0E9468"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#C72E2E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E03E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{DynamicResource HoverBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,1,0"
                                CornerRadius="3,3,0,0" Margin="2,0,0,0">
                            <ContentPresenter x:Name="ContentSite"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ContentSource="Header"
                                            Margin="12,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Border with Drop Shadow -->
    <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" 
                            BlurRadius="20" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Title Bar -->
                <RowDefinition Height="60"/>
                <!-- Status Bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <TextBlock Text="???" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock x:Name="VMNameText" Text="VM Terminal" 
                                 FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                    </StackPanel>

                    <!-- Window Control Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="-" Width="45" Height="40" 
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="16" FontWeight="Bold"
                                Click="Minimize_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1177BB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="?" Width="45" Height="40" 
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="16" FontWeight="Bold"
                                Click="Maximize_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1177BB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="?" Width="45" Height="40" 
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="16" FontWeight="Bold"
                                Click="Close_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C72E2E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- VM Info -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock x:Name="VMIdText" Text="VM ID: Loading..." 
                                 FontSize="11" Foreground="#808080" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ConnectionStatusIcon" Text="??" 
                                     FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ConnectionStatusText" Text="Disconnected" 
                                     FontWeight="SemiBold" FontSize="13" Foreground="#F48771" Margin="0,0,15,0"/>
                            <TextBlock Text="Agent:" FontSize="12" Foreground="#808080" Margin="0,0,5,0"/>
                            <TextBlock x:Name="AgentVersionText" Text="N/A" 
                                     FontSize="12" Foreground="White" Margin="0,0,15,0"/>
                            <TextBlock Text="Last Contact:" FontSize="12" Foreground="#808080" Margin="0,0,5,0"/>
                            <TextBlock x:Name="LastContactText" Text="Never" 
                                     FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="?? Refresh" Style="{StaticResource ModernButton}" 
                                Click="RefreshStatus_Click" Margin="0,0,8,0" Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <TabControl Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="0">
                <!-- Shell Tab -->
                <TabItem Header="?? Shell">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Shell Output -->
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="10">
                            <RichTextBox x:Name="ShellOutput" 
                                       Background="#0C0C0C"
                                       Foreground="White"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="13"
                                       IsReadOnly="True"
                                       VerticalScrollBarVisibility="Auto"
                                       BorderThickness="0"
                                       Padding="10">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Border>

                        <!-- Command Input -->
                        <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,1,0,0" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="$" FontFamily="Consolas" FontSize="14" 
                                         Foreground="#4EC9B0" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <TextBox x:Name="CommandInput" Grid.Column="1"
                                       Style="{StaticResource ModernTextBox}"
                                       KeyDown="CommandInput_KeyDown"
                                       Margin="0,0,10,0"/>

                                <Button Content="? Execute" Grid.Column="2" 
                                      Style="{StaticResource SuccessButton}"
                                      Click="ExecuteCommand_Click" Padding="15,8" Margin="0,0,8,0"/>

                                <Button Content="??? Clear" Grid.Column="3" 
                                      Style="{StaticResource ModernButton}"
                                      Click="ClearShell_Click" Padding="12,8"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Ports Tab -->
                <TabItem Header="?? Ports">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Port Controls -->
                        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Port Management" FontSize="16" FontWeight="SemiBold" 
                                         Foreground="White" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Port:" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <TextBox x:Name="PortNumberInput" Grid.Column="1" 
                                           Style="{StaticResource ModernTextBox}" 
                                           Text="8080" Margin="0,0,10,0"/>

                                    <Button Content="? Open" Grid.Column="2" 
                                          Style="{StaticResource SuccessButton}"
                                          Click="OpenPort_Click" Padding="15,8" Margin="0,0,8,0"/>

                                    <Button Content="? Close" Grid.Column="3" 
                                          Style="{StaticResource DangerButton}"
                                          Click="ClosePort_Click" Padding="15,8" Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                                        <TextBlock Text="Quick:" Foreground="#808080" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="22 SSH" Style="{StaticResource ModernButton}" 
                                              Click="QuickPort_Click" Tag="22" Margin="0,0,5,0" Padding="8,6"/>
                                        <Button Content="80 HTTP" Style="{StaticResource ModernButton}" 
                                              Click="QuickPort_Click" Tag="80" Margin="0,0,5,0" Padding="8,6"/>
                                        <Button Content="443 HTTPS" Style="{StaticResource ModernButton}" 
                                              Click="QuickPort_Click" Tag="443" Margin="0,0,5,0" Padding="8,6"/>
                                        <Button Content="21 FTP" Style="{StaticResource ModernButton}" 
                                              Click="QuickPort_Click" Tag="21" Margin="0,0,5,0" Padding="8,6"/>
                                        <Button Content="3389 RDP" Style="{StaticResource ModernButton}" 
                                              Click="QuickPort_Click" Tag="3389" Padding="8,6"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Port Log -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="10">
                            <RichTextBox x:Name="PortLog" 
                                       Background="#0C0C0C"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       IsReadOnly="True"
                                       VerticalScrollBarVisibility="Auto"
                                       BorderThickness="0"
                                       Padding="10">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Services Tab -->
                <TabItem Header="?? Services">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Service Controls -->
                        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Service Management" FontSize="16" FontWeight="SemiBold" 
                                         Foreground="White" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Service:" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <TextBox x:Name="ServiceNameInput" Grid.Column="1" 
                                           Style="{StaticResource ModernTextBox}" 
                                           Text="nginx" Margin="0,0,10,0"/>

                                    <Button Content="?? Install" Grid.Column="2" 
                                          Style="{StaticResource PrimaryButton}"
                                          Click="InstallService_Click" Padding="12,8" Margin="0,0,8,0"/>

                                    <Button Content="? Start" Grid.Column="3" 
                                          Style="{StaticResource SuccessButton}"
                                          Click="StartService_Click" Padding="12,8" Margin="0,0,8,0"/>

                                    <Button Content="? Stop" Grid.Column="4" 
                                          Style="{StaticResource DangerButton}"
                                          Click="StopService_Click" Padding="12,8" Margin="0,0,8,0"/>

                                    <Button Content="?? Restart" Grid.Column="5" 
                                          Style="{StaticResource ModernButton}"
                                          Click="RestartService_Click" Padding="12,8"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Service Log -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="10">
                            <RichTextBox x:Name="ServiceLog" 
                                       Background="#0C0C0C"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       IsReadOnly="True"
                                       VerticalScrollBarVisibility="Auto"
                                       BorderThickness="0"
                                       Padding="10">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Processes Tab -->
                <TabItem Header="? Processes">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Process Controls -->
                        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" Padding="15">
                            <Grid>
                                <TextBlock Text="Process Monitor" FontSize="16" FontWeight="SemiBold" 
                                         Foreground="White" VerticalAlignment="Center"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="?? Refresh" Style="{StaticResource ModernButton}" 
                                          Click="RefreshProcesses_Click" Padding="12,8" Margin="0,0,8,0"/>
                                    <Button Content="? Kill Process" Style="{StaticResource DangerButton}" 
                                          Click="KillProcess_Click" Padding="12,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Process Grid -->
                        <DataGrid x:Name="ProcessesGrid" Grid.Row="1" 
                                Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="White"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                IsReadOnly="True"
                                Margin="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="80"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="150"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Network Tab -->
                <TabItem Header="?? Network">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Network Controls -->
                        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" Padding="15">
                            <Grid>
                                <TextBlock Text="Network Connections" FontSize="16" FontWeight="SemiBold" 
                                         Foreground="White" VerticalAlignment="Center"/>

                                <Button Content="?? Refresh Connections" Style="{StaticResource ModernButton}" 
                                      Click="RefreshConnections_Click" Padding="12,8" 
                                      HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Network Grid -->
                        <DataGrid x:Name="NetworkGrid" Grid.Row="1" 
                                Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="White"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                IsReadOnly="True"
                                Margin="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80"/>
                                <DataGridTextColumn Header="Local Address" Binding="{Binding LocalAddress}" Width="*"/>
                                <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Logs Tab -->
                <TabItem Header="?? Logs">
                    <Grid Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Controls -->
                        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" Padding="15">
                            <Grid>
                                <TextBlock Text="Agent Logs" FontSize="16" FontWeight="SemiBold" 
                                         Foreground="White" VerticalAlignment="Center"/>

                                <Button Content="??? Clear Logs" Style="{StaticResource ModernButton}" 
                                      Click="ClearLogs_Click" Padding="12,8" 
                                      HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Logs Output -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="10">
                            <RichTextBox x:Name="LogsOutput" 
                                       Background="#0C0C0C"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       IsReadOnly="True"
                                       VerticalScrollBarVisibility="Auto"
                                       BorderThickness="0"
                                       Padding="10">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type Paragraph}">
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
