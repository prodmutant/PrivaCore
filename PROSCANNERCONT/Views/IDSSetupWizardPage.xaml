<Page x:Class="PROSCANNERCONT.Views.IDSSetupWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="IDS Setup"
      Background="{DynamicResource SecondaryBackgroundBrush}">

    <Page.Resources>
        <!-- Storyboards for Animations -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                           From="50" To="0"
                           Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.5"/>
        </Storyboard>

        <!-- Modern Button Style -->
        <Style x:Key="WizardButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="30,15"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Progress Indicator -->
        <ProgressBar x:Name="WizardProgress"
                    Height="4"
                    VerticalAlignment="Top"
                    Value="33"
                    Maximum="100"
                    Background="{DynamicResource HoverBrush}"
                    Foreground="{DynamicResource AccentBrush}"
                    BorderThickness="0"/>

        <!-- Main Content Container -->
        <Grid Margin="0,4,0,0">
            <!-- Step 1: Welcome & Selection -->
            <Grid x:Name="WelcomeStep" Visibility="Visible" Opacity="1">
                <Grid.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Grid.RenderTransform>

                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="1100" Margin="80,60,80,60">

                        <!-- Animated Header -->
                        <Grid Height="140" Margin="0,0,0,40">
                            <Ellipse Width="140" Height="140" 
                                    Fill="{DynamicResource AccentBrush}" 
                                    Opacity="0.1"
                                    HorizontalAlignment="Center"/>
                            <Ellipse Width="100" Height="100" 
                                    Fill="{DynamicResource AccentBrush}" 
                                    Opacity="0.2"
                                    HorizontalAlignment="Center">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="0" CenterX="50" CenterY="50"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                               From="0" To="360"
                                                               Duration="0:0:30"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <fa:IconBlock Icon="Shield" 
                                          Foreground="White"
                                          FontSize="60"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Welcome Title -->
                        <TextBlock Text="Intrusion Detection System"
                                  FontSize="48"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>

                        <TextBlock Text="Professional network security monitoring and threat detection"
                                  FontSize="18"
                                  Foreground="{DynamicResource SubtleTextBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,60"/>

                        <!-- Introduction Card -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="50" 
                               CornerRadius="12"
                               Margin="0,0,0,50">
                            <StackPanel>
                                <TextBlock Text="Choose Your Deployment Model"
                                          FontSize="26"
                                          FontWeight="SemiBold"
                                          Foreground="White"
                                          Margin="0,0,0,20"/>

                                <TextBlock TextWrapping="Wrap"
                                          FontSize="16"
                                          Foreground="{DynamicResource TextBrush}"
                                          LineHeight="28">
                                    Select the IDS deployment type that best fits your security requirements. Each model offers unique capabilities tailored to different monitoring scenarios and infrastructure needs.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Deployment Cards -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Host-Based Card -->
                            <Border x:Name="HostCard"
                                   Grid.Column="0"
                                   Background="{DynamicResource SecondaryBackgroundBrush}"
                                   BorderBrush="{DynamicResource BorderBrush}"
                                   BorderThickness="3"
                                   CornerRadius="12"
                                   Padding="40"
                                   Cursor="Hand"
                                   MouseEnter="HostCard_MouseEnter"
                                   MouseLeave="HostCard_MouseLeave"
                                   MouseLeftButtonUp="SelectHostBased_Click">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>

                                <StackPanel>
                                    <!-- Icon -->
                                    <Border Width="90" Height="90"
                                           Background="{DynamicResource SuccessBrush}"
                                           CornerRadius="45"
                                           Margin="0,0,0,25">
                                        <fa:IconBlock Icon="Desktop" 
                                                       Foreground="White"
                                                       FontSize="40"/>
                                    </Border>

                                    <!-- Title -->
                                    <TextBlock Text="Host-Based IDS"
                                              FontSize="28"
                                              FontWeight="Bold"
                                              Foreground="White"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,15"/>

                                    <!-- Subtitle -->
                                    <TextBlock Text="Endpoint Security"
                                              FontSize="14"
                                              Foreground="{DynamicResource SuccessBrush}"
                                              HorizontalAlignment="Center"
                                              FontWeight="SemiBold"
                                              Margin="0,0,0,30"/>

                                    <!-- Features -->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="System log analysis"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="File integrity monitoring"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Process monitoring"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Registry change detection"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource SuccessBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Local threat detection"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Best For -->
                                    <Border Background="Transparent"
                                           BorderBrush="{DynamicResource SuccessBrush}"
                                           BorderThickness="1"
                                           CornerRadius="6"
                                           Padding="15"
                                           Margin="0,30,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                  FontSize="13"
                                                  Foreground="{DynamicResource SuccessBrush}">
                                            <Run Text="Best for:" FontWeight="Bold"/><LineBreak/>
                                            <Run Text="Single workstations, laptops, servers, development machines"/>
                                        </TextBlock>
                                    </Border>

                                    <!-- Action Hint -->
                                    <TextBlock Text="Click to configure →"
                                              FontSize="14"
                                              Foreground="{DynamicResource SubtleTextBrush}"
                                              HorizontalAlignment="Center"
                                              Margin="0,25,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Network-Based Card -->
                            <Border x:Name="NetworkCard"
                                   Grid.Column="2"
                                   Background="{DynamicResource SecondaryBackgroundBrush}"
                                   BorderBrush="{DynamicResource BorderBrush}"
                                   BorderThickness="3"
                                   CornerRadius="12"
                                   Padding="40"
                                   Cursor="Hand"
                                   MouseEnter="NetworkCard_MouseEnter"
                                   MouseLeave="NetworkCard_MouseLeave"
                                   MouseLeftButtonUp="SelectNetworkBased_Click">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>

                                <StackPanel>
                                    <!-- Icon -->
                                    <Border Width="90" Height="90"
                                           Background="{DynamicResource AccentBrush}"
                                           CornerRadius="45"
                                           Margin="0,0,0,25">
                                        <fa:IconBlock Icon="Globe" 
                                                       Foreground="White"
                                                       FontSize="40"/>
                                    </Border>

                                    <!-- Title -->
                                    <TextBlock Text="Network-Based IDS"
                                              FontSize="28"
                                              FontWeight="Bold"
                                              Foreground="White"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,15"/>

                                    <!-- Subtitle -->
                                    <TextBlock Text="Network Security"
                                              FontSize="14"
                                              Foreground="{DynamicResource AccentBrush}"
                                              HorizontalAlignment="Center"
                                              FontWeight="SemiBold"
                                              Margin="0,0,0,30"/>

                                    <!-- Features -->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Real-time traffic analysis"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Packet inspection"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Protocol anomaly detection"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Attack signature matching"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8">
                                            <fa:IconBlock Icon="Check" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          FontSize="14"
                                                          Margin="0,0,12,0"
                                                          VerticalAlignment="Center"/>
                                            <TextBlock Text="Network-wide monitoring"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      FontSize="15"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Best For -->
                                    <Border Background="Transparent"
                                           BorderBrush="{DynamicResource AccentBrush}"
                                           BorderThickness="1"
                                           CornerRadius="6"
                                           Padding="15"
                                           Margin="0,30,0,0">
                                        <TextBlock TextWrapping="Wrap"
                                                  FontSize="13"
                                                  Foreground="{DynamicResource AccentBrush}">
                                            <Run Text="Best for:" FontWeight="Bold"/><LineBreak/>
                                            <Run Text="Enterprise networks, DMZ monitoring, perimeter defense"/>
                                        </TextBlock>
                                    </Border>

                                    <!-- Action Hint -->
                                    <TextBlock Text="Click to configure →"
                                              FontSize="14"
                                              Foreground="{DynamicResource SubtleTextBrush}"
                                              HorizontalAlignment="Center"
                                              Margin="0,25,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Step 2: Host-Based Configuration -->
            <Grid x:Name="HostDetailsStep" Visibility="Collapsed" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Grid.RenderTransform>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="950" Margin="60,40,60,60">

                        <!-- Back Navigation -->
                        <Button Content="← Back to Selection"
                               Click="BackToWelcome_Click"
                               Style="{StaticResource SecondaryButton}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,40"/>

                        <!-- Header with Icon -->
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,50">
                            <Border Width="70" Height="70"
                                   Background="{DynamicResource SuccessBrush}"
                                   CornerRadius="35"
                                   Margin="0,0,25,0">
                                <fa:IconBlock Icon="Desktop" 
                                              Foreground="White"
                                              FontSize="35"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Host-Based IDS"
                                          FontSize="36"
                                          FontWeight="Bold"
                                          Foreground="White"/>
                                <TextBlock Text="Single system monitoring and protection"
                                          FontSize="16"
                                          Foreground="{DynamicResource SubtleTextBrush}"
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Overview Section -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <fa:IconBlock Icon="CircleInfo" 
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="How It Works"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock TextWrapping="Wrap"
                                          FontSize="15"
                                          Foreground="{DynamicResource TextBrush}"
                                          LineHeight="26">
                                    Host-Based IDS (HIDS) operates directly on this computer, providing deep visibility into system-level activities. It monitors operating system logs, file system changes, process execution, and network connections originating from this host. HIDS excels at detecting insider threats, malware, rootkits, and unauthorized system modifications.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- System Requirements -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <fa:IconBlock Icon="Gears" 
                                                   Foreground="{DynamicResource SeverityMediumBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="System Requirements"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Minimum -->
                                    <Border Grid.Column="0"
                                           Background="{DynamicResource HoverBrush}"
                                           Padding="25"
                                           CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Minimum"
                                                      FontSize="16"
                                                      FontWeight="Bold"
                                                      Foreground="{DynamicResource SeverityMediumBrush}"
                                                      Margin="0,0,0,15"/>

                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="CPU:" FontWeight="SemiBold"/>
                                                    <Run Text="Dual-core 2.0 GHz"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="RAM:" FontWeight="SemiBold"/>
                                                    <Run Text="4 GB"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Storage:" FontWeight="SemiBold"/>
                                                    <Run Text="10 GB available"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Network:" FontWeight="SemiBold"/>
                                                    <Run Text="100 Mbps"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recommended -->
                                    <Border Grid.Column="2"
                                           Background="{DynamicResource HoverBrush}"
                                           Padding="25"
                                           CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Recommended"
                                                      FontSize="16"
                                                      FontWeight="Bold"
                                                      Foreground="{DynamicResource SuccessBrush}"
                                                      Margin="0,0,0,15"/>

                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="CPU:" FontWeight="SemiBold"/>
                                                    <Run Text="Quad-core 3.0+ GHz"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="RAM:" FontWeight="SemiBold"/>
                                                    <Run Text="8+ GB"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Storage:" FontWeight="SemiBold"/>
                                                    <Run Text="50+ GB SSD"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Network:" FontWeight="SemiBold"/>
                                                    <Run Text="1 Gbps"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Monitoring Capabilities -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,40">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <fa:IconBlock Icon="Eye" 
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="Monitoring Capabilities"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="• Windows Event Logs" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• File Integrity Monitoring" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Registry Monitoring" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• User Authentication" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="• Process Activity" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Service Changes" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Network Connections" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• USB Device Tracking" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Configure Button -->
                        <Button Content="Configure Host-Based IDS"
                               Click="ConfigureHostBased_Click"
                               Style="{StaticResource WizardButton}"
                               HorizontalAlignment="Center"
                               FontSize="16"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Step 3: Network-Based Configuration -->
            <Grid x:Name="NetworkDetailsStep" Visibility="Collapsed" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Grid.RenderTransform>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="950" Margin="60,40,60,60">

                        <!-- Back Navigation -->
                        <Button Content="← Back to Selection"
                               Click="BackToWelcome_Click"
                               Style="{StaticResource SecondaryButton}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,40"/>

                        <!-- Header with Icon -->
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,50">
                            <Border Width="70" Height="70"
                                   Background="{DynamicResource AccentBrush}"
                                   CornerRadius="35"
                                   Margin="0,0,25,0">
                                <fa:IconBlock Icon="Globe" 
                                              Foreground="White"
                                              FontSize="35"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Network-Based IDS"
                                          FontSize="36"
                                          FontWeight="Bold"
                                          Foreground="White"/>
                                <TextBlock Text="Enterprise network traffic monitoring"
                                          FontSize="16"
                                          Foreground="{DynamicResource SubtleTextBrush}"
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Overview Section -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <fa:IconBlock Icon="CircleInfo" 
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="How It Works"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock TextWrapping="Wrap"
                                          FontSize="15"
                                          Foreground="{DynamicResource TextBrush}"
                                          LineHeight="26">
                                    Network-Based IDS (NIDS) monitors network traffic in real-time, analyzing packets for malicious patterns and anomalies. Positioned at strategic network points, NIDS provides comprehensive visibility into all network communications. It's ideal for detecting network-based attacks, port scans, DDoS attempts, and data exfiltration across your entire infrastructure.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- System Requirements -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <fa:IconBlock Icon="Gears" 
                                                   Foreground="{DynamicResource SeverityMediumBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="System Requirements"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Minimum -->
                                    <Border Grid.Column="0"
                                           Background="{DynamicResource HoverBrush}"
                                           Padding="25"
                                           CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Minimum"
                                                      FontSize="16"
                                                      FontWeight="Bold"
                                                      Foreground="{DynamicResource SeverityMediumBrush}"
                                                      Margin="0,0,0,15"/>

                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="CPU:" FontWeight="SemiBold"/>
                                                    <Run Text="Quad-core 2.5 GHz"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="RAM:" FontWeight="SemiBold"/>
                                                    <Run Text="8 GB"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Storage:" FontWeight="SemiBold"/>
                                                    <Run Text="100 GB available"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Network:" FontWeight="SemiBold"/>
                                                    <Run Text="1 Gbps NIC"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recommended -->
                                    <Border Grid.Column="2"
                                           Background="{DynamicResource HoverBrush}"
                                           Padding="25"
                                           CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Recommended"
                                                      FontSize="16"
                                                      FontWeight="Bold"
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      Margin="0,0,0,15"/>

                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="CPU:" FontWeight="SemiBold"/>
                                                    <Run Text="8+ cores 3.5+ GHz"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="RAM:" FontWeight="SemiBold"/>
                                                    <Run Text="16+ GB"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Storage:" FontWeight="SemiBold"/>
                                                    <Run Text="500+ GB SSD"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="14">
                                                    <Run Text="Network:" FontWeight="SemiBold"/>
                                                    <Run Text="10 Gbps NIC"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Network Placement -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <fa:IconBlock Icon="Sitemap" 
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="Strategic Placement"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock TextWrapping="Wrap"
                                          FontSize="15"
                                          Foreground="{DynamicResource TextBrush}"
                                          LineHeight="26"
                                          Margin="0,0,0,20">
                                    Position your NIDS sensor at critical network choke points for maximum coverage:
                                </TextBlock>

                                <StackPanel>
                                    <Border Background="Transparent"
                                           BorderBrush="{DynamicResource AccentBrush}"
                                           BorderThickness="1"
                                           Padding="15"
                                           CornerRadius="6">
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="14">
                                            <Run Text="• Perimeter Defense:" FontWeight="SemiBold"/>
                                            <Run Text="Behind the firewall to monitor all ingress/egress traffic"/>
                                        </TextBlock>
                                    </Border>

                                    <Border Background="Transparent"
                                           BorderBrush="{DynamicResource AccentBrush}"
                                           BorderThickness="1"
                                           Padding="15"
                                           CornerRadius="6">
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="14">
                                            <Run Text="• DMZ Monitoring:" FontWeight="SemiBold"/>
                                            <Run Text="Between DMZ and internal network for public service protection"/>
                                        </TextBlock>
                                    </Border>

                                    <Border Background="Transparent"
                                           BorderBrush="{DynamicResource AccentBrush}"
                                           BorderThickness="1"
                                           Padding="15"
                                           CornerRadius="6">
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="14">
                                            <Run Text="• Internal Segmentation:" FontWeight="SemiBold"/>
                                            <Run Text="Between network VLANs for lateral movement detection"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Monitoring Capabilities -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                               Padding="40" 
                               CornerRadius="12"
                               Margin="0,0,0,40">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <fa:IconBlock Icon="Eye" 
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="24"
                                                   Margin="0,0,15,0"/>
                                    <TextBlock Text="Monitoring Capabilities"
                                              FontSize="22"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="• Deep Packet Inspection" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Protocol Analysis" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Attack Signatures" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Anomaly Detection" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="• Port Scan Detection" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• DDoS Identification" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Data Exfiltration" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                        <TextBlock Text="• Malware C&amp;C Traffic" 
                                                  Foreground="{DynamicResource TextBrush}" 
                                                  FontSize="15" 
                                                  Margin="0,8"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Configure Button -->
                        <Button Content="Configure Network-Based IDS"
                               Click="ConfigureNetworkBased_Click"
                               Style="{StaticResource WizardButton}"
                               HorizontalAlignment="Center"
                               FontSize="16"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
