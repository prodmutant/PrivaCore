<Page x:Class="PROSCANNERCONT.Views.HostIDSDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" Background="{DynamicResource BackgroundBrush}" Title="Host IDS">
  <Page.Resources>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderThickness" Value="0"/><Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="RowBackground" Value="{DynamicResource SecondaryBackgroundBrush}"/>
      <Setter Property="ColumnHeaderHeight" Value="32"/><Setter Property="RowHeight" Value="26"/><Setter Property="FontSize" Value="12"/>
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/><Setter Property="CanUserAddRows" Value="False"/><Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="IsReadOnly" Value="True"/><Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/><Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/><Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="8,0"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/></Trigger>
        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{DynamicResource SelectionBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Padding" Value="8,3"/><Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridCell">
            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/><Setter Property="FontSize" Value="12"/>
      <Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/><Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Bd" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="14,10">
              <ContentPresenter ContentSource="Header"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ABtn" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="FontSize" Value="11"/><Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="Padding" Value="12,6"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- Row styles re-used across tabs -->
    <Style x:Key="CritRow" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding Severity}" Value="Critical"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource CriticalBrush}"/></DataTrigger>
        <DataTrigger Binding="{Binding Severity}" Value="High"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/></DataTrigger>
        <DataTrigger Binding="{Binding Severity}" Value="Medium"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/></DataTrigger>
        <DataTrigger Binding="{Binding IsNew}" Value="True"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource CriticalBrush}"/></DataTrigger>
      </Style.Triggers>
    </Style>
    <DataTemplate x:Key="SevBadge">
      <Border CornerRadius="3" Padding="5,2" HorizontalAlignment="Left" Background="{Binding SeverityColor}">
        <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="{DynamicResource PrimaryFont}"/>
      </Border>
    </DataTemplate>
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- HEADER -->
    <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{DynamicResource HoverBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,14,0">
            <TextBlock Text="HIDS" Foreground="{DynamicResource SuccessBrush}" FontSize="13" FontWeight="Bold" FontFamily="Consolas"/>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Host-Based Intrusion Detection System" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontFamily="{DynamicResource PrimaryFont}"/>
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
              <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{DynamicResource SeverityCriticalBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
              <TextBlock x:Name="StatusLabel" Text="OFFLINE — click Start Monitoring" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" FontFamily="{DynamicResource PrimaryFont}"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>
        <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="MonitoringToggleButton" Content="▶  Start Monitoring" Click="ToggleMonitoring_Click"
                  Style="{StaticResource ABtn}" Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource SuccessBrush}" BorderBrush="{DynamicResource BorderBrush}"
                  FontSize="12" FontWeight="SemiBold" Padding="16,7" Margin="0,0,6,0"/>
          <Button Content="↺  Refresh"      Click="RefreshDashboard_Click" Style="{StaticResource ABtn}" Padding="11,7" Margin="0,0,4,0"/>
          <Button Content="⬇  Export CSV"   Click="ExportCsv_Click"        Style="{StaticResource ABtn}" Padding="11,7" Margin="0,0,4,0"/>
          <Button Content="📄 Report"        Click="ExportReport_Click"     Style="{StaticResource ABtn}" Padding="11,7" Margin="0,0,4,0" Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
          <Button Content="📥 Import Config" Click="ImportConfig_Click"     Style="{StaticResource ABtn}" Padding="11,7" Margin="0,0,4,0" Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource WarningBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
          <Button Content="📤 Export Config" Click="ExportConfig_Click"     Style="{StaticResource ABtn}" Padding="11,7" Margin="0,0,4,0" Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource WarningBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
          <Button Content="⚙  Settings"      Click="Settings_Click"         Style="{StaticResource ABtn}" Padding="11,7"/>
        </WrapPanel>
      </Grid>
    </Border>

    <!-- MODE SWITCHER -->
    <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,8">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="IDS MODE" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" Margin="0,0,18,0"/>
        <Button Click="SwitchToNids_Click" Style="{StaticResource ABtn}" Padding="16,5" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0">
          <TextBlock Text="⊞  Network IDS" FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource SubtleTextBrush}"/>
        </Button>
        <Border Background="{DynamicResource HoverBrush}" CornerRadius="4" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" Padding="16,5" VerticalAlignment="Center">
          <TextBlock Text="⊟  Host IDS" Foreground="{DynamicResource SuccessBrush}" FontSize="12" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
        </Border>
      </StackPanel>
    </Border>

    <!-- STAT CARDS -->
    <Grid Grid.Row="2" Margin="16,10,16,0">
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="5" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Text="FILE CHANGES"     Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
          <TextBlock x:Name="FileChangesText" Text="0" Foreground="{DynamicResource SuccessBrush}" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
          <TextBlock Text="C:\Windows + custom" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontFamily="{DynamicResource PrimaryFont}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="5" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Text="SUSPICIOUS PROCS"  Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
          <TextBlock x:Name="ProcessAlertsText" Text="0" Foreground="{DynamicResource SeverityCriticalBrush}" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
          <TextBlock Text="incl. parent-child LOLBin" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontFamily="{DynamicResource PrimaryFont}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="5" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Text="SECURITY EVENTS"   Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
          <TextBlock x:Name="SecurityEventsText" Text="0" Foreground="{DynamicResource SeverityMediumBrush}" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
          <TextBlock Text="Event Log (12 IDs)" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontFamily="{DynamicResource PrimaryFont}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="5" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Text="REGISTRY CHANGES"  Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
          <TextBlock x:Name="RegChangesText" Text="0" Foreground="{DynamicResource SeverityCriticalBrush}" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
          <TextBlock Text="Run / RunOnce / Services" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontFamily="{DynamicResource PrimaryFont}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="4" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12,8">
        <StackPanel>
          <TextBlock Text="SYSTEM HEALTH"     Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
          <TextBlock x:Name="SystemHealthText" Text="Good" Foreground="{DynamicResource SuccessBrush}" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
          <TextBlock Text="threat activity score" Foreground="{DynamicResource SubtleTextBrush}" FontSize="9" FontFamily="{DynamicResource PrimaryFont}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- MONITORING STRIP -->
    <Border Grid.Row="3" Margin="16,8,16,0" CornerRadius="4" Background="{DynamicResource HoverBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12,5">
      <TextBlock FontFamily="Consolas" FontSize="10" Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap">
        <Run FontWeight="Bold" Text="Monitoring:  "/>
        <Run Text="Events: 1102 4625 4648 4672 4688 4697 4698 4720 4732 4756 4776 7045  ·  "/>
        <Run Text="Files: C:\Windows + System32 + SysWOW64 + custom (with SHA256 hash on change)  ·  "/>
        <Run Text="Processes: WMI full cmdline + parent-child anomaly (Office→shell, Browser→shell)  ·  "/>
        <Run Text="Registry: Run/RunOnce/Services (HKLM+HKCU)  ·  Services · Tasks · Sessions · DNS cache"/>
      </TextBlock>
    </Border>

    <!-- TABS -->
    <TabControl Grid.Row="4" Background="{DynamicResource BackgroundBrush}" BorderThickness="0" Margin="16,6,16,12">

      <!-- SECURITY EVENTS -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📋  Security Events" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource WarningBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="EventCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="Win Security Log polled every 5s · last 5 min · 12 critical event IDs · structured field extraction · Double-click row for full detail"/>
          </Border>
          <DataGrid x:Name="EventLogList" Grid.Row="1" MouseDoubleClick="EventLogList_DoubleClick">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Time"    Binding="{Binding Time}"     Width="75" FontFamily="Consolas"/>
              <DataGridTemplateColumn Header="Sev" Width="78" CellTemplate="{StaticResource SevBadge}"/>
              <DataGridTextColumn Header="Event"   Binding="{Binding Title}"    Width="220"/>
              <DataGridTextColumn Header="Details" Binding="{Binding Detail}"   Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- FILE INTEGRITY -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📁  File Integrity" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource SeverityLowBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="FileCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="FileSystemWatcher on C:\Windows + System32 + custom paths · SHA256 hash on change · Double-click for full path + hash"/>
          </Border>
          <DataGrid x:Name="FileChangesList" Grid.Row="1" MouseDoubleClick="FileList_DoubleClick">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Time"     Binding="{Binding Time}"   Width="75" FontFamily="Consolas"/>
              <DataGridTemplateColumn Header="Sev"  Width="78" CellTemplate="{StaticResource SevBadge}"/>
              <DataGridTextColumn Header="Change"   Binding="{Binding Title}"  Width="90"/>
              <DataGridTextColumn Header="Path / Hash" Binding="{Binding Detail}" Width="*" FontFamily="Consolas"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- PROCESSES -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="⚙  Processes" VerticalAlignment="Center"/>
            <Border x:Name="ProcBadge" Background="{DynamicResource CriticalBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="ProcCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="WMI: full command line · parent-child anomaly (Office→shell = macro attack) · suspicious exec paths · Double-click for full detail"/>
          </Border>
          <DataGrid x:Name="ProcessList" Grid.Row="1" MouseDoubleClick="ProcessList_DoubleClick">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSuspicious}" Value="True"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource CriticalBrush}"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="PID"         Binding="{Binding Pid}"          Width="55" FontFamily="Consolas"/>
              <DataGridTemplateColumn Header="Flag" Width="20" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate><Ellipse Width="7" Height="7" HorizontalAlignment="Center" Fill="{Binding SeverityColor}"/></DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Name"        Binding="{Binding Name}"         Width="130"/>
              <DataGridTextColumn Header="Parent"      Binding="{Binding ParentName}"   Width="120"/>
              <DataGridTextColumn Header="RAM"         Binding="{Binding RamMB}"        Width="70" FontFamily="Consolas"/>
              <DataGridTextColumn Header="Reason / Command Line" Binding="{Binding DisplayDetail}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- REGISTRY -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🔑  Registry" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource CriticalBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="RegCountBadge" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="Polling Run/RunOnce (HKLM+HKCU) + Services + custom keys · diff vs baseline · any change = Critical (persistence)"/>
          </Border>
          <DataGrid x:Name="RegistryChangesList" Grid.Row="1">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Time"   Binding="{Binding Time}"   Width="75" FontFamily="Consolas"/>
              <DataGridTemplateColumn Header="Sev" Width="78" CellTemplate="{StaticResource SevBadge}"/>
              <DataGridTextColumn Header="Change" Binding="{Binding Title}"  Width="180"/>
              <DataGridTextColumn Header="Key / Old → New" Binding="{Binding Detail}" Width="*" FontFamily="Consolas"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- SERVICES -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🔧  Services" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource CriticalBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="SvcCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="WMI Win32_Service · baselining on start · RED row = service appeared after baseline (new service = Critical) · Double-click for detail"/>
          </Border>
          <DataGrid x:Name="ServicesList" Grid.Row="1" MouseDoubleClick="ServiceList_DoubleClick">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="New" Width="36" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Ellipse Width="7" Height="7" HorizontalAlignment="Center"
                             Fill="{Binding SeverityColor}"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Name"         Binding="{Binding Name}"        Width="160"/>
              <DataGridTextColumn Header="State"        Binding="{Binding State}"        Width="80"/>
              <DataGridTextColumn Header="Start Mode"   Binding="{Binding StartMode}"    Width="90"/>
              <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}"  Width="200"/>
              <DataGridTextColumn Header="Binary Path"  Binding="{Binding PathName}"     Width="*" FontFamily="Consolas"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- SCHEDULED TASKS -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📅  Tasks" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource WarningBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="TaskCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="schtasks /query CSV · baselining on start · ORANGE badge = new task appeared after baseline · SYSTEM tasks flagged as Medium"/>
          </Border>
          <DataGrid x:Name="TasksList" Grid.Row="1">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Flag" Width="20" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate><Ellipse Width="7" Height="7" HorizontalAlignment="Center" Fill="{Binding SeverityColor}"/></DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Task Name"  Binding="{Binding TaskName}"  Width="*"/>
              <DataGridTextColumn Header="Status"     Binding="{Binding Status}"    Width="90"/>
              <DataGridTextColumn Header="Run As"     Binding="{Binding RunAs}"     Width="140" FontFamily="Consolas"/>
              <DataGridTextColumn Header="Author"     Binding="{Binding Author}"    Width="130"/>
              <DataGridTextColumn Header="Next Run"   Binding="{Binding NextRun}"   Width="140" FontFamily="Consolas"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- CONNECTIONS -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🌐  Connections" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="ConnCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="netstat -ano with PID · ORANGE = suspicious port (4444 5555 6666 1337 31337 9001 +custom) · includes proto and state"/>
          </Border>
          <DataGrid x:Name="NetworkConnectionsList" Grid.Row="1">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Time"          Binding="{Binding Time}"   Width="75" FontFamily="Consolas"/>
              <DataGridTemplateColumn Header="Flag" Width="18" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate><Ellipse Width="7" Height="7" HorizontalAlignment="Center" Fill="{Binding SeverityColor}"/></DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Proto / State / PID" Binding="{Binding Title}"  Width="200" FontFamily="Consolas"/>
              <DataGridTextColumn Header="Local → Remote"      Binding="{Binding Detail}" Width="*"   FontFamily="Consolas"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- SESSIONS -->
      <TabItem Header="👤  Sessions">
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="'query session' output · baselining on start · new sessions flagged · RDP sessions = Medium · new RDP = High"/>
          </Border>
          <DataGrid x:Name="SessionsList" Grid.Row="1">
            <DataGrid.RowStyle><Style TargetType="DataGridRow" BasedOn="{StaticResource CritRow}"/></DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Flag" Width="20" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate><Ellipse Width="7" Height="7" HorizontalAlignment="Center" Fill="{Binding SeverityColor}"/></DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Session"  Binding="{Binding SessionName}" Width="140" FontFamily="Consolas"/>
              <DataGridTextColumn Header="User"     Binding="{Binding UserName}"    Width="160"/>
              <DataGridTextColumn Header="State"    Binding="{Binding State}"       Width="100"/>
              <DataGridTextColumn Header="Type"     Binding="{Binding Type}"        Width="80"/>
              <DataGridTextColumn Header="New?"     Binding="{Binding IsNew}"       Width="60"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- DNS CACHE -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🌍  DNS Cache" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource WarningBrush}" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="DnsCountText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" FontFamily="{DynamicResource PrimaryFont}"/>
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{DynamicResource BackgroundBrush}">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                       Text="ipconfig /displaydns · Shannon entropy check · suspicious TLD detection (.tk .ml .ga .cf .xyz +) · long subdomain (DNS tunnel) · Double-click for detail"/>
          </Border>
          <DataGrid x:Name="DnsList" Grid.Row="1" MouseDoubleClick="DnsList_DoubleClick">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSuspicious}" Value="True"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/></DataTrigger>
                  <DataTrigger Binding="{Binding Severity}" Value="High"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Flag" Width="20" CanUserResize="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate><Ellipse Width="7" Height="7" HorizontalAlignment="Center" Fill="{Binding SeverityColor}"/></DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Domain"      Binding="{Binding Domain}"     Width="*"   FontFamily="Consolas"/>
              <DataGridTextColumn Header="Type"        Binding="{Binding RecordType}" Width="60"/>
              <DataGridTextColumn Header="Data"        Binding="{Binding Data}"       Width="140" FontFamily="Consolas"/>
              <DataGridTextColumn Header="Entropy"     Binding="{Binding EntropyStr}" Width="70"/>
              <DataGridTextColumn Header="Reason"      Binding="{Binding Reason}"     Width="280"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

    </TabControl>
  </Grid>
</Page>
