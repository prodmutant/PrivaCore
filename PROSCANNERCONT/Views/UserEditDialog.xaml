<Window x:Class="PROSCANNERCONT.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="12" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Margin="26,22,26,22">
            <TextBlock x:Name="TitleText" Text="New user" FontSize="19" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,18"/>

            <Border x:Name="ErrorBanner" Visibility="Collapsed" Margin="0,0,0,14"
                    Background="#26FF7B72" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="10,7">
                <TextBlock x:Name="ErrorText" Foreground="{DynamicResource CriticalBrush}" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <StackPanel x:Name="IdentityFields">
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Style="{DynamicResource InputBoxStyle}" Height="38" Margin="0,0,0,12"/>
                <TextBlock Text="Display name" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="DisplayBox" Style="{DynamicResource InputBoxStyle}" Height="38" Margin="0,0,0,12"/>
                <TextBlock Text="Role" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5"/>
                <ComboBox x:Name="RoleBox" Style="{DynamicResource ComboBoxStyle}" Height="38" Margin="0,0,0,12"/>
            </StackPanel>

            <TextBlock x:Name="PwLabel" Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Style="{DynamicResource PasswordBoxStyle}" Height="38" Margin="0,0,0,12"/>
            <TextBlock Text="Confirm password" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmBox" Style="{DynamicResource PasswordBoxStyle}" Height="38" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Style="{DynamicResource GhostButtonStyle}" Height="38" Width="96" Margin="0,0,10,0"/>
                <Button x:Name="OkButton" Content="Create" Click="Ok_Click" Style="{DynamicResource AccentButtonStyle}" Height="38" Width="120"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
