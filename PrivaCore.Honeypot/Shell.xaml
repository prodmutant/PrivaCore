<Window x:Class="PrivaCore.Honeypot.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PrivaCore Honeypot — Module" Height="860" Width="1360"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" WindowStyle="None"
        Background="{DynamicResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Themed title bar -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <fa:IconBlock DockPanel.Dock="Left" Icon="Bug" FontSize="13" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="12,0,8,0"/>
                <TextBlock DockPanel.Dock="Left" Text="PrivaCore Honeypot — Module" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionButtonStyle}" Click="Min_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Minimize"/>
                    <Button x:Name="MaxBtn" Content="&#xE922;" Style="{StaticResource CaptionButtonStyle}" Click="Max_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Maximize"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CaptionCloseButtonStyle}" Click="CloseWin_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Close"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Running: honeypot sensor status -->
        <DockPanel x:Name="RunningView" Grid.Row="1" Visibility="Collapsed">
            <!-- status strip -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                <DockPanel>
                    <fa:IconBlock DockPanel.Dock="Left" Icon="Bug" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                    <TextBlock DockPanel.Dock="Left" Text="Honeypot Sensor" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                    <Button DockPanel.Dock="Right" Content="Reconfigure" Click="Reconfigure_Click" Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="New pairing code" Click="NewPairing_Click" Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="RunStatus" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock x:Name="ConnInfo" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{DynamicResource SubtleTextBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="ReachText" Margin="18,0,12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SubtleTextBrush}"/>
                </DockPanel>
            </Border>

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- add decoy -->
                <Border Grid.Row="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                    <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Decoy service" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ServiceKindBox" Width="130" Height="34" Style="{DynamicResource ComboBoxStyle}" Margin="0,0,10,0"/>
                        <TextBlock Text="Port" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="DecoyPortBox" Width="80" Height="34" Text="2323" Style="{DynamicResource InputBoxStyle}" Margin="0,0,10,0"/>
                        <Button Content="Start decoy" Click="StartDecoy_Click" Style="{DynamicResource AccentButtonStyle}" Height="34" Padding="14,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="Content" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Width="520" Margin="0,0,10,0">
                            <TextBox x:Name="DecoyContentBox" Height="34" Style="{DynamicResource InputBoxStyle}"/>
                            <TextBlock IsHitTestVisible="False" Foreground="{DynamicResource DisabledTextBrush}" Margin="12,0,0,0"
                                       VerticalAlignment="Center" FontSize="12" Text="e.g. &lt;html&gt;…&lt;/html&gt; for HTTP, or a login banner">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=DecoyContentBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="HTTP → HTML page to serve   ·   Telnet/SSH/FTP → banner   (optional)" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    </StackPanel>
                </Border>

                <!-- KPI -->
                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,10,0" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,3,0,0">
                        <StackPanel><TextBlock Text="ACTIVE DECOYS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/><TextBlock x:Name="KpiDecoys" Text="0" Foreground="{DynamicResource TextBrush}" FontSize="28" FontWeight="Bold"/></StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,10,0" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="0,3,0,0">
                        <StackPanel><TextBlock Text="TOTAL HITS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/><TextBlock x:Name="KpiHits" Text="0" Foreground="{DynamicResource WarningBrush}" FontSize="28" FontWeight="Bold"/></StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,10,0" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="0,3,0,0">
                        <StackPanel><TextBlock Text="CREDENTIALS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/><TextBlock x:Name="KpiCreds" Text="0" Foreground="{DynamicResource CriticalBrush}" FontSize="28" FontWeight="Bold"/></StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="16" BorderBrush="{DynamicResource AccentLightBrush}" BorderThickness="0,3,0,0">
                        <StackPanel><TextBlock Text="ATTACKERS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"/><TextBlock x:Name="KpiAttackers" Text="0" Foreground="{DynamicResource AccentLightBrush}" FontSize="28" FontWeight="Bold"/></StackPanel>
                    </Border>
                </Grid>

                <!-- decoys + hits -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="14" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="RUNNING DECOYS" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="DecoysList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="13">
                                                        <Run Text="{Binding KindName, Mode=OneWay}"/><Run Text="  :"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Foreground="{DynamicResource SubtleTextBrush}" FontSize="11"><Run Text="{Binding Hits, Mode=OneWay}"/><Run Text=" hits"/></TextBlock>
                                                    <TextBlock Text="{Binding Endpoints, Mode=OneWay}" Foreground="{DynamicResource AccentLightBrush}" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Stop" Tag="{Binding}" Click="StopDecoy_Click" Style="{DynamicResource GhostButtonStyle}" Height="28" Padding="10,0" Foreground="{DynamicResource CriticalBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoDecoysText" Text="No decoys running — add one above." Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="LIVE CAPTURES" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="16,14,0,8"/>
                            <DataGrid x:Name="HitsGrid" Grid.Row="1" Style="{DynamicResource DataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" Margin="8,0,8,8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding TimeText}"/>
                                    <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}"/>
                                    <DataGridTextColumn Header="Tags" Binding="{Binding TagsText}"/>
                                    <DataGridTextColumn Header="Source IP" Binding="{Binding SourceIp}"/>
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="2*"/>
                                    <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="*"/>
                                    <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- Config gate -->
        <Grid x:Name="ConfigOverlay" Grid.Row="1" Background="{DynamicResource BackgroundBrush}">
            <Border Style="{StaticResource CardStyle}" Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <fa:IconBlock Icon="Bug" FontSize="24" Foreground="{DynamicResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PrivaCore Honeypot Module" Style="{StaticResource HeaderTextStyle}"/>
                            <TextBlock Text="Configure how the console connects to this honeypot." Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Listen port (control channel)" Style="{StaticResource MutedTextStyle}" Margin="0,14,0,3"/>
                    <TextBox x:Name="PortBox" Text="9710" Style="{StaticResource InputBoxStyle}"/>
                    <TextBlock Text="Username" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,3"/>
                    <TextBox x:Name="UserBox" Text="admin" Style="{StaticResource InputBoxStyle}"/>
                    <TextBlock Text="Password" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,3"/>
                    <PasswordBox x:Name="PassBox" Style="{StaticResource PasswordBoxStyle}"/>
                    <TextBlock Text="Confirm password" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,3"/>
                    <PasswordBox x:Name="Pass2Box" Style="{StaticResource PasswordBoxStyle}"/>
                    <TextBlock Text="Pairing code (deployment secret — give this to console operators)" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,3"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Generate" Click="Generate_Click" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0"/>
                        <TextBox x:Name="PairBox" Style="{StaticResource InputBoxStyle}"/>
                    </DockPanel>
                    <Button Content="Save &amp; Start module" Style="{StaticResource AccentButtonStyle}" Margin="0,20,0,0" Height="40" Click="SaveStart_Click"/>
                    <TextBlock x:Name="ErrText" Foreground="{DynamicResource CriticalBrush}" TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
