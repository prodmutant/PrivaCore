		<Compile Include="..\PROSCANNERCONT\Services\ModuleThemeSync.cs" Link="_Linked\Services\ModuleThemeSync.cs" />

		<Page Include="..\PROSCANNERCONT\Views\Networkidsdashboardpage.xaml" Link="_Linked\Views\Networkidsdashboardpage.xaml" />
		<Compile Include="..\PROSCANNERCONT\Views\Networkidsdashboardpage.xaml.cs" Link="_Linked\Views\Networkidsdashboardpage.xaml.cs" />
		<Page Include="..\PROSCANNERCONT\Views\Hostidsdashboardpage.xaml" Link="_Linked\Views\Hostidsdashboardpage.xaml" />
		<Compile Include="..\PROSCANNERCONT\Views\Hostidsdashboardpage.xaml.cs" Link="_Linked\Views\Hostidsdashboardpage.xaml.cs" />
		<Page Include="..\PROSCANNERCONT\Views\IDSSetupWizardPage.xaml" Link="_Linked\Views\IDSSetupWizardPage.xaml" />
